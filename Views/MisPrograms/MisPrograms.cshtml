@{
    ViewData["Title"] = "MIS 系統 - 程式項目";
    ViewBag.HeaderTitle = "MIS 系統 - 程式項目";
    ViewBag.HeaderIcon = @"<svg class=""w-6 h-6"" fill=""none"" stroke=""currentColor"" viewBox=""0 0 24 24""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4""></path></svg>";
}

@section Styles {
    <link rel="stylesheet" href="~/css/mis_programs.css" asp-append-version="true">
}

<div class="flex h-screen bg-slate-50 overflow-hidden">
    <!-- Sidebar -->
    <partial name="Components/_Sidebar" />

    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
        <!-- Header -->
        <partial name="Components/_Header" />

        <!-- Main Content -->
        <main class="flex-1 overflow-auto p-6">
            <!-- Page Header -->
            <div class="mb-6">
                <h1 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                    <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    MIS 程式項目列表
                </h1>
                <p class="text-slate-600 mt-1">查看和管理系統程式項目</p>
            </div>

            <!-- Error Message -->
            @if (ViewBag.Error != null)
            {
                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4">
                    <strong>錯誤：</strong> @ViewBag.Error
                </div>
            }

            <!-- Filter Panel -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 mb-6">
                <h3 class="font-bold text-slate-700 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
                    篩選條件
                </h3>
                <form method="get" action="/mis/programs" class="grid grid-cols-1 md:grid-cols-4 gap-4">
                    <div class="relative">
                        <label class="block text-sm font-medium text-slate-700 mb-1">程式代號</label>
                        <input type="text" name="program_no" value="@ViewBag.ProgramNoFilter"
                               class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                               placeholder="輸入程式代號..." autocomplete="off">
                        <!-- Suggestion dropdown -->
                        <div id="suggestionList" class="absolute z-[60] w-full mt-1 bg-white rounded-xl shadow-2xl border border-slate-200 hidden overflow-hidden transition-all duration-200 opacity-0 transform -translate-y-2">
                            <!-- Items will be injected by JS -->
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">負責人員</label>
                        <input type="text" name="employee_id" value="@ViewBag.EmployeeIdFilter"
                               class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                               placeholder="員工編號...">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">顯示狀態</label>
                        <select name="display_code" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="">全部</option>
                            @if (ViewBag.DisplayCodeFilter == "Y")
                            {
                                <option value="Y" selected>顯示</option>
                            }
                            else
                            {
                                <option value="Y">顯示</option>
                            }

                            @if (ViewBag.DisplayCodeFilter == "N")
                            {
                                <option value="N" selected>隱藏</option>
                            }
                            else
                            {
                                <option value="N">隱藏</option>
                            }
                        </select>
                    </div>
                    <div class="flex items-end gap-2">
                        <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium transition-colors">
                            查詢
                        </button>
                        <button type="button" onclick="runProgram()" class="flex-1 bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg font-medium transition-colors">
                            執行程式
                        </button>
                        <a href="/mis/programs" class="px-4 py-2 border border-slate-300 text-center rounded-lg hover:bg-slate-50 transition-colors inline-block leading-10">
                            重置
                        </a>
                    </div>
                </form>
            </div>

            <!-- Tree View -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                    <div class="flex justify-between items-center">
                        <h3 class="font-bold text-slate-700">
                            程式項目 <span class="text-sm font-normal text-slate-500">(共 @(ViewBag.Programs?.Count ?? 0) 筆)</span>
                        </h3>
                    </div>
                </div>

                <div class="p-4">
                    @if (ViewBag.Categories != null && ViewBag.Categories.Count > 0)
                    {
                        <div class="tree-container">
                            @foreach (var category in ViewBag.Categories)
                            {
                                string systemName = category.Key;
                                var programs = category.Value as List<Dictionary<string, object>>;

                                <!-- System Level -->
                                <div class="tree-node">
                                    <div class="tree-item system-level" onclick="toggleNode(this)">
                                        <svg class="arrow" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                                            <path d="M6 4l4 4-4 4V4z" />
                                        </svg>
                                        <svg class="folder-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                                        </svg>
                                        <span class="tree-label">@systemName (@programs.Count)</span>
                                    </div>

                                    <div class="tree-children" style="display: none;">
                                        @foreach (var program in programs)
                                        {
                                            string pNo = program.ContainsKey("PROGRAM_NO") ? program["PROGRAM_NO"]?.ToString() : "";
                                            string pName = program.ContainsKey("PROGRAM_NAME") ? program["PROGRAM_NAME"]?.ToString() : "";
                                            string pPurpose = program.ContainsKey("PURPOSE") ? program["PURPOSE"]?.ToString() : "";
                                            string eId = program.ContainsKey("EMPLOYEE_ID") ? program["EMPLOYEE_ID"]?.ToString() : "";
                                            string pStart = program.ContainsKey("PLAN_START_DEVELOP_DATE") ? program["PLAN_START_DEVELOP_DATE"]?.ToString() : "";
                                            string pFinish = program.ContainsKey("PLAN_FINISH_DEVELOP_DATE") ? program["PLAN_FINISH_DEVELOP_DATE"]?.ToString() : "";
                                            string rStart = program.ContainsKey("REAL_START_DEVELOP_DATE") ? program["REAL_START_DEVELOP_DATE"]?.ToString() : "";
                                            string rFinish = program.ContainsKey("REAL_FINISH_DEVELOP_DATE") ? program["REAL_FINISH_DEVELOP_DATE"]?.ToString() : "";
                                            string pHours = program.ContainsKey("PLAN_WORK_HOURS") ? program["PLAN_WORK_HOURS"]?.ToString() : "";
                                            string rHours = program.ContainsKey("REAL_WORK_HOURS") ? program["REAL_WORK_HOURS"]?.ToString() : "";
                                            string pType = program.ContainsKey("PROGRAM_TYPE") ? program["PROGRAM_TYPE"]?.ToString() : "";
                                            string displayCode = program.ContainsKey("DISPLAY_CODE") ? program["DISPLAY_CODE"]?.ToString() : "";

                                            <!-- Program Level -->
                                            <div class="tree-item program-level"
                                                 onclick="openProgramModal(this)"
                                                 data-program-no="@pNo"
                                                 data-program-name="@pName"
                                                 data-purpose="@pPurpose"
                                                 data-employee-id="@eId"
                                                 data-plan-start="@pStart"
                                                 data-plan-finish="@pFinish"
                                                 data-real-start="@rStart"
                                                 data-real-finish="@rFinish"
                                                 data-plan-hours="@pHours"
                                                 data-real-hours="@rHours"
                                                 data-program-type="@pType">
                                                <svg class="file-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                                </svg>
                                                <span class="program-no font-mono">@pNo</span>
                                                <span class="program-name font-medium text-slate-700 ml-4">@(string.IsNullOrEmpty(pName) ? "-" : pName)</span>
                                                <span class="program-purpose text-sm text-slate-500 ml-4 hidden md:inline">@pPurpose</span>
                                                @if (displayCode == "Y")
                                                {
                                                    <span class="status-badge active ml-auto">顯示</span>
                                                }
                                                else
                                                {
                                                    <span class="status-badge inactive ml-auto">隱藏</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-12 text-slate-500">
                            <svg class="w-12 h-12 mx-auto mb-3 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                            <p class="text-lg font-medium">無符合條件的資料</p>
                            <p class="text-sm mt-1">請調整篩選條件後重新查詢</p>
                        </div>
                    }
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Program Detail Modal Overlay -->
<div id="programModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden z-50 items-center justify-center p-4 transition-all duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-4xl max-h-[90vh] flex flex-col overflow-hidden border border-slate-200 transform scale-95 transition-transform duration-300" id="modalContent">
        <!-- Modal Header -->
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white px-6 py-5 flex items-center justify-between shadow-lg">
            <h2 class="text-xl font-bold flex items-center gap-3">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z" />
                </svg>
                程式詳細資訊
            </h2>
            <div class="flex items-center gap-1">
                <button type="button" class="text-blue-100 hover:text-white hover:bg-white/10 p-2 rounded-lg transition-all" onclick="toggleMaximizeModal()" id="maximizeBtn">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="maximizeIcon">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                    </svg>
                    <svg class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="restoreIcon">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 9L4 4m0 0v4m0-4h4m12 12l-5-5m5 5v-4m0 4h-4M9 15l-5 5m0 0v-4m0 4h4m11-11l-5 5m5-5v4m0-4h-4" />
                    </svg>
                </button>
                <button type="button" class="text-blue-100 hover:text-white hover:bg-white/10 p-2 rounded-lg transition-all" onclick="closeProgramModal()">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- Modal Body -->
        <div class="flex-1 overflow-y-auto bg-slate-50 p-8">
            <!-- Program Identity -->
            <div class="mb-8 flex flex-col md:flex-row md:items-center border-b border-slate-200 pb-6 gap-4">
                <span id="modal-program-no" class="text-4xl font-black text-blue-600 font-mono tracking-tighter"></span>
                <span id="modal-program-name" class="text-2xl text-slate-700 font-semibold md:ml-2"></span>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <!-- Left Column -->
                <div class="space-y-6">
                    <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
                        <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            基本資訊
                        </h4>
                        <div class="space-y-5">
                            <div>
                                <label class="block text-xs font-semibold text-slate-400 mb-1">用途說明</label>
                                <p id="modal-purpose" class="text-lg text-slate-800 leading-relaxed font-medium"></p>
                            </div>
                            <div class="grid grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-xs font-semibold text-slate-400 mb-1">負責人員</label>
                                    <span id="modal-employee-id" class="px-3 py-1 bg-blue-50 text-blue-700 rounded-lg font-mono text-sm font-bold border border-blue-100 inline-block"></span>
                                </div>
                                <div>
                                    <label class="block text-xs font-semibold text-slate-400 mb-1">程式類型</label>
                                    <p id="modal-program-type" class="text-sm text-slate-700 font-medium"></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="space-y-6">
                    <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
                        <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            時程與工時
                        </h4>

                        <div class="grid grid-cols-2 gap-8">
                            <!-- Plan -->
                            <div class="space-y-4">
                                <h5 class="text-xs font-black text-slate-500 border-b border-slate-100 pb-2">計畫時程</h5>
                                <div class="space-y-3">
                                    <div>
                                        <label class="block text-[10px] text-slate-400 uppercase font-bold">開始日期</label>
                                        <p id="modal-plan-start" class="text-sm font-mono text-slate-600">-</p>
                                    </div>
                                    <div>
                                        <label class="block text-[10px] text-slate-400 uppercase font-bold">預計完成</label>
                                        <p id="modal-plan-finish" class="text-sm font-mono text-slate-600">-</p>
                                    </div>
                                    <div>
                                        <label class="block text-[10px] text-slate-400 uppercase font-bold">預估工時</label>
                                        <p id="modal-plan-hours" class="text-sm font-mono text-slate-600">-</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Real -->
                            <div class="space-y-4">
                                <h5 class="text-xs font-black text-blue-600 border-b border-blue-100 pb-2">實際執行</h5>
                                <div class="space-y-3">
                                    <div>
                                        <label class="block text-[10px] text-blue-400 uppercase font-bold">實際開始</label>
                                        <p id="modal-real-start" class="text-sm font-mono text-blue-700 font-bold">-</p>
                                    </div>
                                    <div>
                                        <label class="block text-[10px] text-blue-400 uppercase font-bold">實際完成</label>
                                        <p id="modal-real-finish" class="text-sm font-mono text-blue-700 font-bold">-</p>
                                    </div>
                                    <div>
                                        <label class="block text-[10px] text-blue-400 uppercase font-bold">累計工時</label>
                                        <p id="modal-real-hours" class="text-sm font-mono text-blue-700 font-bold">-</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white border-t border-slate-200 px-8 py-6 flex justify-end items-center">
            <button type="button" class="px-8 py-2.5 bg-slate-700 hover:bg-slate-800 text-white rounded-full font-bold flex items-center gap-2 transition-all transform hover:scale-105 shadow-lg active:scale-95" onclick="closeProgramModal()">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                關閉
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/mis_programs.js" asp-append-version="true"></script>
}
