п»ҝ@{
    ViewData["Title"] = "MIS иқҹйӨҢзөһ - иқ”п•қ??пҶұоӯ–";
    ViewBag.HeaderTitle = "MIS иқҹйӨҢзөһ - иқ”п•қ??пҶұоӯ–";
    ViewBag.HeaderIcon = @"<svg class=""w-6 h-6"" fill=""none"" stroke=""currentColor"" viewBox=""0 0 24 24""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""2"" d=""M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4""></path></svg>";
}

@section Styles {
    <link rel="stylesheet" href="~/css/mis_programs.css" asp-append-version="true">
}

<div class="flex h-screen bg-slate-50 overflow-hidden">

    <!-- Sidebar -->
    <partial name="Components/_Sidebar" />

    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">

        <!-- Header -->
        <partial name="Components/_Header" />

        <!-- Main Content -->
        <main class="flex-1 overflow-auto p-6">

            <!-- ===== ?ојҝоІ„з’…о©—?еҡ—пҢӘ-page-titleеҡ—?==== -->
            <g-page-title title="MIS иқ”п•қ??пҶұоӯ–?оӨңвҖқ"
                          subtitle="?дәҰ??п—јжҒЈ?пүҺй ӮиқҜжўҒ?ж’ҳоҗө???
                          icon="database">
            </g-page-title>

            <!-- ===== ?иҲӘзӮҠй–®п“Ғој…еҡ—пҢӘ-alertеҡ—?==== -->
            @if (ViewBag.Error != null)
            {
                <g-alert type="error" message="@ViewBag.Error" dismissible="true"></g-alert>
            }

            <!-- ===== иқӯжӢҡојҺз’ҮоіҶиҫЈеҡ—пҢӘ-panelеҡ—?==== -->
            <g-panel title="иқӯжӢҡојҺз’ҮоіҶиҫЈ" icon="filter" class="mb-6">
                <form method="get" action="/mis/programs" class="grid grid-cols-1 md:grid-cols-4 gap-4">

                    <!-- иқ”п•қ?йҡһ??еҡ—пҺҶо’” Suggestion Dropdownеҡ—?->
                    <div class="flex flex-col gap-1">
                        <label class="block text-sm font-medium text-slate-700 mb-1">иқ”п•қ?йҡһ??</label>
                        <div class="relative">
                            <input type="text" name="program_no" id="inputProgramNo"
                                   value="@ViewBag.ProgramNoFilter"
                                   class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
                                   placeholder="й ӣи©Ёп…Ҝиқ”п•қ?йҡһ??..." autocomplete="off">
                            <!-- JS зҳңе…ёп…Ҝ Suggestion dropdown -->
                            <div id="suggestionList"
                                 class="absolute z-[60] w-full mt-1 bg-white rounded-xl shadow-2xl border border-slate-200 hidden overflow-hidden transition-all duration-200 opacity-0 transform -translate-y-2">
                            </div>
                        </div>
                    </div>

                    <!-- иІ иІ¬дәәе“ЎпјҲLOVпјү -->
                    <g-lov-input label="иІ иІ¬дәәе“Ў"
                                 code-id="employee_id"
                                 code-value="@ViewBag.EmployeeIdFilter"
                                 code-placeholder="е“Ўе·Ҙз·Ёиҷҹ..."
                                 lov-title="е°Ӣжүҫе“Ўе·Ҙ (Employee)"
                                 lov-api="/api/lov/hrm/employees"
                                 lov-columns="з·Ёиҷҹ,еҗҚзЁұ,ID"
                                 lov-fields="employee_no,employee_name,employee_id"
                                 lov-key-code="employee_id"
                                 lov-sort-enabled="true"
                                 lov-buffer-view="true"
                                 lov-page-size="50">
                    </g-lov-input>

                    <!-- жҶҝиҲҗе…§?ВҖ??-->
                    <div class="flex flex-col gap-1">
                        <label class="block text-sm font-medium text-slate-700 mb-1">жҶҝиҲҗе…§?ВҖ??/label>
                        <select name="display_code"
                                class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="">?еҲёпҖё</option>
                            <option value="Y" @(ViewBag.DisplayCodeFilter == "Y" ? "selected" : "")>жҶҝиҲҗе…§</option>
                            <option value="N" @(ViewBag.DisplayCodeFilter == "N" ? "selected" : "")>?жўҜ?</option>
                        </select>
                    </div>

                    <!-- ?пҡ–??пҗ§? -->
                    <div class="flex items-end gap-2">
                        <g-button text="?дәҘеІ·" icon="search"  type="primary" submit="true"           class="flex-1"></g-button>
                        <g-button text="?з‘Ғ?" icon="play"    type="success" onclick="runProgram()"  class="flex-1"></g-button>
                        <g-button text="?пҡҷи”ӯ" icon="refresh" type="ghost"   href="/mis/programs"    class="flex-1"></g-button>
                    </div>
                </form>
            </g-panel>

            <!-- ===== иқ”п•қ??пҶұоӯ–з’…еҜ§??оӨңвҖқеҡ—пҢӘ-panelеҡ—?==== -->
            <g-panel icon="list">
                <!-- з’…о©—??оҳүеұҖйӣҝиј»оң…?иҠҫ? slot ?жү№жҚҶ -->
                <div slot="title" class="flex justify-between items-center w-full">
                    <span class="font-bold text-slate-700">
                        иқ”п•қ??пҶұоӯ–
                        <span class="text-sm font-normal text-slate-500">
                            еҡ—пҺҶп…» @(ViewBag.Programs?.Count ?? 0) иқ‘пү–?
                        </span>
                    </span>
                </div>

                @if (ViewBag.Categories != null && ViewBag.Categories.Count > 0)
                {
                    <div class="tree-container">
                        @foreach (var category in ViewBag.Categories)
                        {
                            string systemName = category.Key;
                            var programs = category.Value as List<Dictionary<string, object>>;

                            <!-- System Level -->
                            <div class="tree-node">
                                <div class="tree-item system-level" onclick="toggleNode(this)">
                                    <svg class="arrow" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
                                        <path d="M6 4l4 4-4 4V4z" />
                                    </svg>
                                    <svg class="folder-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                                    </svg>
                                    <span class="tree-label">@systemName (@programs.Count)</span>
                                </div>

                                <div class="tree-children" style="display: none;">
                                    @foreach (var program in programs)
                                    {
                                        string pNo          = program.ContainsKey("PROGRAM_NO")                ? program["PROGRAM_NO"]?.ToString()                ?? "" : "";
                                        string pName        = program.ContainsKey("PROGRAM_NAME")              ? program["PROGRAM_NAME"]?.ToString()              ?? "" : "";
                                        string pPurpose     = program.ContainsKey("PURPOSE")                   ? program["PURPOSE"]?.ToString()                   ?? "" : "";
                                        string eId          = program.ContainsKey("EMPLOYEE_ID")               ? program["EMPLOYEE_ID"]?.ToString()               ?? "" : "";
                                        string pStart       = program.ContainsKey("PLAN_START_DEVELOP_DATE")   ? program["PLAN_START_DEVELOP_DATE"]?.ToString()   ?? "" : "";
                                        string pFinish      = program.ContainsKey("PLAN_FINISH_DEVELOP_DATE")  ? program["PLAN_FINISH_DEVELOP_DATE"]?.ToString()  ?? "" : "";
                                        string rStart       = program.ContainsKey("REAL_START_DEVELOP_DATE")   ? program["REAL_START_DEVELOP_DATE"]?.ToString()   ?? "" : "";
                                        string rFinish      = program.ContainsKey("REAL_FINISH_DEVELOP_DATE")  ? program["REAL_FINISH_DEVELOP_DATE"]?.ToString()  ?? "" : "";
                                        string pHours       = program.ContainsKey("PLAN_WORK_HOURS")           ? program["PLAN_WORK_HOURS"]?.ToString()           ?? "" : "";
                                        string rHours       = program.ContainsKey("REAL_WORK_HOURS")           ? program["REAL_WORK_HOURS"]?.ToString()           ?? "" : "";
                                        string pType        = program.ContainsKey("PROGRAM_TYPE")              ? program["PROGRAM_TYPE"]?.ToString()              ?? "" : "";
                                        string displayCode  = program.ContainsKey("DISPLAY_CODE")              ? program["DISPLAY_CODE"]?.ToString()              ?? "" : "";

                                        <!-- Program Level -->
                                        <div class="tree-item program-level"
                                             onclick="openProgramModal(this)"
                                             data-program-no="@pNo"
                                             data-program-name="@pName"
                                             data-purpose="@pPurpose"
                                             data-employee-id="@eId"
                                             data-plan-start="@pStart"
                                             data-plan-finish="@pFinish"
                                             data-real-start="@rStart"
                                             data-real-finish="@rFinish"
                                             data-plan-hours="@pHours"
                                             data-real-hours="@rHours"
                                             data-program-type="@pType">
                                            <svg class="file-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                      d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                            </svg>
                                            <span class="program-no font-mono">@pNo</span>
                                            <span class="program-name font-medium text-slate-700 ml-4">@(string.IsNullOrEmpty(pName) ? "-" : pName)</span>
                                            <span class="program-purpose text-sm text-slate-500 ml-4 hidden md:inline">@pPurpose</span>
                                            @if (displayCode == "Y")
                                            {
                                                <span class="status-badge active ml-auto">жҶҝиҲҗе…§</span>
                                            }
                                            else
                                            {
                                                <span class="status-badge inactive ml-auto">?жўҜ?</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <!-- ?вҲҹ??о©қ?g-empty-stateеҡ—?->
                    <g-empty-state title="?вҲ жіө?пҺҮ?йҡһе—Ҙ?йһҲпӢӘ?"
                                   subtitle="йҡўп• зҹҪ?жёЎзҘҹ?иұў?йҡһе—…??пҡҳоЎҮ?дәҘеІ·"
                                   icon="search">
                    </g-empty-state>
                }
            </g-panel>

        </main>
    </div>
</div>

<!-- ===== иқ”п•қ?й–°е–ҹж•ҰйһҲпӢ¬? Modalеҡ—пҺҶ??зҘҶ???200+ йҠөпҳ„?йқҪоіү? JS йҲӯоҳҲ?йҠқпҡ—?еҡ—?==== -->
<div id="programModal"
     class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden z-50 items-center justify-center p-4 transition-all duration-300">
    <div id="modalContent"
         class="bg-white rounded-2xl shadow-2xl w-full max-w-4xl max-h-[90vh] flex flex-col overflow-hidden border border-slate-200 transform scale-95 transition-transform duration-300">

        <!-- Modal Header -->
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white px-6 py-5 flex items-center justify-between shadow-lg">
            <h2 class="text-xl font-bold flex items-center gap-3">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z" />
                </svg>
                иқ”п•қ?й–°е–ҹж•ҰйһҲпӢ¬?
            </h2>
            <div class="flex items-center gap-1">
                <button type="button" id="maximizeBtn" onclick="toggleMaximizeModal()"
                        class="text-blue-100 hover:text-white hover:bg-white/10 w-8 h-8 flex items-center justify-center rounded-lg transition-all relative">
                    <svg id="maximizeIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                    </svg>
                    <svg id="restoreIcon" class="w-[85%] h-[85%] hidden absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 9L4 4m0 0v4m0-4h4m12 12l-5-5m5 5v-4m0 4h-4M9 15l-5 5m0 0v-4m0 4h4m11-11l-5 5m5-5v4m0-4h-4"></path>
                    </svg>
                </button>
                <button type="button" onclick="closeProgramModal()"
                        class="text-blue-100 hover:text-white hover:bg-white/10 p-2 rounded-lg transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- Modal Body -->
        <div class="flex-1 overflow-y-auto bg-slate-50 p-8">
            <!-- иқ”п•қ?иқәеҲ»? + ?пҡҷиҝӮ -->
            <div class="mb-8 flex flex-col md:flex-row md:items-center border-b border-slate-200 pb-6 gap-4">
                <span id="modal-program-no" class="text-4xl font-black text-blue-600 font-mono tracking-tighter"></span>
                <span id="modal-program-name" class="text-2xl text-slate-700 font-semibold md:ml-2"></span>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <!-- ж’ҢиЎҢ?еҡ—о«°о·–?зҘҲ?й–®?-->
                <div class="space-y-6">
                    <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
                        <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            ?з®ёоҜұйһҲпӢ¬?
                        </h4>
                        <div class="space-y-5">
                            <div>
                                <label class="block text-xs font-semibold text-slate-400 mb-1">?еҲёВҖоқ…зү§??/label>
                                <p id="modal-purpose" class="text-lg text-slate-800 leading-relaxed font-medium"></p>
                            </div>
                            <div class="grid grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-xs font-semibold text-slate-400 mb-1">йһҺоәЎз—ҠйҲӯз®ҸоҷЎ</label>
                                    <span id="modal-employee-id" class="px-3 py-1 bg-blue-50 text-blue-700 rounded-lg font-mono text-sm font-bold border border-blue-100 inline-block"></span>
                                </div>
                                <div>
                                    <label class="block text-xs font-semibold text-slate-400 mb-1">иқ”п•қ?жҶҝоөӨ?</label>
                                    <p id="modal-program-type" class="text-sm text-slate-700 font-medium"></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ?е–®?еҡ—о«ұ?иқ”п• ?ж’ҢдәӨ? -->
                <div class="space-y-6">
                    <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
                        <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4 flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            ?оҝҡ??пӢ©жҘө??
                        </h4>
                        <div class="grid grid-cols-2 gap-8">
                            <!-- й–®пҺҲоһҘ?оҝҡ? -->
                            <div class="space-y-4">
                                <h5 class="text-xs font-black text-slate-500 border-b border-slate-100 pb-2">й–®пҺҲоһҘ?оҝҡ?</h5>
                                <div class="space-y-3">
                                    <div>
                                        <label class="block text-[10px] text-slate-400 uppercase font-bold">?п•қ??дәӨ?</label>
                                        <p id="modal-plan-start" class="text-sm font-mono text-slate-600">-</p>
                                    </div>
                                    <div>
                                        <label class="block text-[10px] text-slate-400 uppercase font-bold">?о“‘?ж‘°п—»?</label>
                                        <p id="modal-plan-finish" class="text-sm font-mono text-slate-600">-</p>
                                    </div>
                                    <div>
                                        <label class="block text-[10px] text-slate-400 uppercase font-bold">?о“Қж‘Ҝж’ҢдәӨ?</label>
                                        <p id="modal-plan-hours" class="text-sm font-mono text-slate-600">-</p>
                                    </div>
                                </div>
                            </div>
                            <!-- ж’–йҳЎ??з‘Ғ? -->
                            <div class="space-y-4">
                                <h5 class="text-xs font-black text-blue-600 border-b border-blue-100 pb-2">ж’–йҳЎ??з‘Ғ?</h5>
                                <div class="space-y-3">
                                    <div>
                                        <label class="block text-[10px] text-blue-400 uppercase font-bold">ж’–йҳЎ??п•қ?</label>
                                        <p id="modal-real-start" class="text-sm font-mono text-blue-700 font-bold">-</p>
                                    </div>
                                    <div>
                                        <label class="block text-[10px] text-blue-400 uppercase font-bold">ж’–йҳЎ?ж‘°п—»?</label>
                                        <p id="modal-real-finish" class="text-sm font-mono text-blue-700 font-bold">-</p>
                                    </div>
                                    <div>
                                        <label class="block text-[10px] text-blue-400 uppercase font-bold">иққиҲӘ?ж’ҢдәӨ?</label>
                                        <p id="modal-real-hours" class="text-sm font-mono text-blue-700 font-bold">-</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal Footer -->
        <div class="bg-white border-t border-slate-200 px-8 py-6 flex justify-end items-center gap-4">
            <a href="#" id="btnOpenProgram"
               class="px-8 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white rounded-full font-bold flex items-center gap-2 transition-all transform hover:scale-105 shadow-lg active:scale-95">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
                ?и„Јп…Ҝиқ”п•қ?
            </a>
            <button type="button" onclick="closeProgramModal()"
                    class="px-8 py-2.5 bg-slate-700 hover:bg-slate-800 text-white rounded-full font-bold flex items-center gap-2 transition-all transform hover:scale-105 shadow-lg active:scale-95">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                ?о°®?й–°е–ҹж•ҰйһҲпӢ¬?
            </button>
        </div>
    </div>
</div>

<!-- ===== иқ”п•қ??з‘Ғ?й–¬оЎҫ?еҡ—пҢӘ-iframe-modalеҡ—?==== -->
<g-iframe-modal
    id="executionModal"
    modal-content-id="executionModalContent"
    iframe-id="executionIframe"
    title-id="executionModalTitle"
    title="иқ”п•қ??з‘Ғ?"
    gradient="indigo"
    maximize-btn-id="execMaximizeBtn"
    maximize-icon-id="execMaximizeIcon"
    restore-icon-id="execRestoreIcon"
    close-fn="closeExecutionModal()"
    maximize-fn="toggleExecutionMaximize()"
    height="95vh">
</g-iframe-modal>

@section Scripts {
    <script src="~/js/sidebar.js" asp-append-version="true"></script>
    <script src="~/js/mis_programs.js" asp-append-version="true"></script>
}
