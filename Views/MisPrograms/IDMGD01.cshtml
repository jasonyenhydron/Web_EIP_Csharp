@{
    var _viewName = System.IO.Path.GetFileNameWithoutExtension(ViewContext.ExecutingFilePath);
    ViewData["Title"] = ViewBag.ProgramTitle ?? _viewName;
    Layout = "~/Views/Shared/_PopupLayout.cshtml";
    var employeeLovSql = Uri.EscapeDataString(@"
SELECT employee_id, employee_no, employee_name
FROM (
    SELECT employee_id, employee_no, employee_name,
           ROW_NUMBER() OVER (ORDER BY employee_no ASC) AS rn
    FROM hrm_employee_v
    WHERE (UPPER(employee_no) LIKE :q OR UPPER(employee_name) LIKE :q)
)
WHERE rn > :offset AND rn <= :endRow");
    var employeeLovApi = $"/api/lov/query?sql={employeeLovSql}";
}

<div class="absolute inset-0 flex flex-col bg-slate-50 overflow-hidden" x-data="idmgd01App()" x-init="init()">

    <div class="bg-white border-b border-slate-200 px-4 py-3 shrink-0">
        <div class="flex flex-wrap items-end gap-3">
            <g-textbox label="程式編號"
                       x-model="search.programNo"
                       x-on-enter="executeQuery()"
                       extra-class="w-36 uppercase"
                       wrapper-class="flex flex-col gap-1">
            </g-textbox>

            <g-lov-input label="員工編號"
                         hidden-id="searchEmployeeId" x-model-hidden="search.employeeId"
                         code-id="searchEmployeeNo" code-placeholder="員工" code-width="w-20"
                         name-id="searchEmployeeName"
                         lov-title="尋找員工 (Employee)"
                         lov-api="@employeeLovApi"
                         lov-columns="編號,名稱,ID"
                         lov-fields="employee_no,employee_name,employee_id"
                         lov-key-hidden="employee_id"
                         lov-key-code="employee_no"
                         lov-key-name="employee_name">
            </g-lov-input>

            <g-combobox label="顯示碼"
                        name="displayCode"
                        x-model="search.displayCode"
                        items="Y:Y,N:N"
                        placeholder="全部">
            </g-combobox>

            <g-button text="查詢" icon="search" type="primary" onclick="window._idmApp?.executeQuery()"></g-button>

            <div class="ml-auto text-xs text-slate-500">操作欄支援 檢視 / 編輯 / 刪除</div>
        </div>
    </div>

    <div class="flex flex-col flex-1 min-h-0 overflow-hidden">
        <g-datagrid id="idmGrid"
                    api="/Idm/select?DataMember=IDMGD01"
                    columns="PROGRAM_NO:程式編號:150:left:text::text,DISPLAY_CODE:顯示:80:center:select:Y=Y;N=N:select,EMPLOYEE_ID:員工編號:150:left:text::lov,PURPOSE:用途:220:left:text::text,PROGRAM_TYPE:程式型態:120:left:text::text,ENTRY_DATE:建檔日期:170:left:readonly::"
                    pagination="true"
                    page-list="20,50,100"
                    page-size="20"
                    always-close="false"
                    not-init-grid="false"
                    row-numbers="true"
                    edit-mode="form"
                    query-auto-column="true"
                    allow-add="true"
                    allow-update="true"
                    allow-delete="true"
                    view-command-visible="true"
                    on-insert="idmOpenCreate"
                    on-view="idmViewRecord"
                    on-update="idmEditRecord"
                    on-row-click="idmSelectProgram"
                    @@add="openCreate()"
                    @@view="viewRecord($event.detail.row)"
                    @@edit="editRecord($event.detail.row)"
                    @@delete="confirmDelete($event.detail.row)"
                    @@query="executeQueryFromGrid($event.detail.filters)"
                    extra-class="flex-1 min-h-0 max-h-[52vh]"
                    clean-style="false"></g-datagrid>

        <div class="border-t border-slate-200 bg-white px-3 py-2 text-sm text-slate-700">
            主檔：<span class="font-semibold" x-text="selectedProgram?.PROGRAM_NO || '-'"></span>
            <span class="text-slate-400 ml-2" x-text="selectedProgram?.PURPOSE || '請先點選上方程式資料'"></span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-3 p-3 pb-4 bg-slate-50 border-t border-slate-200 min-h-[340px]">
            <g-datagrid id="roleGrid1"
                        title="位置一"
                        api="/Idm/selectRoleFunctionPrograms?DataMember=IDMGD01&positionNo=1"
                        columns="ROLE_NO:角色:100:left:text::text,ROLE_NAME:角色名稱:150:left:text::text,FUNCTION_NO:功能編號:120:left:text::text,DISPLAY_ORDER:序:60:right:number::number,DISPLAY_COLOR:顏色:90:left:text::text"
                        page-size="8"
                        row-numbers="false"
                        pagination="true"
                        allow-add="true"
                        allow-update="true"
                        allow-delete="true"
                        auto-apply="false"
                        on-insert="idmAddRole1"
                        on-update="idmEditRole1"
                        on-delete="idmDeleteRole">
            </g-datagrid>

            <g-datagrid id="roleGrid2"
                        title="位置二"
                        api="/Idm/selectRoleFunctionPrograms?DataMember=IDMGD01&positionNo=2"
                        columns="ROLE_NO:角色:100:left:text::text,ROLE_NAME:角色名稱:150:left:text::text,FUNCTION_NO:功能編號:120:left:text::text,DISPLAY_ORDER:序:60:right:number::number,DISPLAY_COLOR:顏色:90:left:text::text"
                        page-size="8"
                        row-numbers="false"
                        pagination="true"
                        allow-add="true"
                        allow-update="true"
                        allow-delete="true"
                        auto-apply="false"
                        on-insert="idmAddRole2"
                        on-update="idmEditRole2"
                        on-delete="idmDeleteRole">
            </g-datagrid>

            <g-datagrid id="roleGrid3"
                        title="位置三"
                        api="/Idm/selectRoleFunctionPrograms?DataMember=IDMGD01&positionNo=3"
                        columns="ROLE_NO:角色:100:left:text::text,ROLE_NAME:角色名稱:150:left:text::text,FUNCTION_NO:功能編號:120:left:text::text,DISPLAY_ORDER:序:60:right:number::number,DISPLAY_COLOR:顏色:90:left:text::text"
                        page-size="8"
                        row-numbers="false"
                        pagination="true"
                        allow-add="true"
                        allow-update="true"
                        allow-delete="true"
                        auto-apply="false"
                        on-insert="idmAddRole3"
                        on-update="idmEditRole3"
                        on-delete="idmDeleteRole">
            </g-datagrid>
        </div>
    </div>

<g-dialog id="dlgRecord" title="程式資料" width="lg">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <g-textbox label="程式編號"
                   required="true"
                   x-model="formRecord.PROGRAM_NO"
                   x-bind-readonly="recordMode!=='create'"
                   placeholder="例：IDMGD99"
                   extra-class="uppercase">
        </g-textbox>

        <g-combobox label="顯示碼"
                    x-model="formRecord.DISPLAY_CODE"
                    x-bind-disabled="recordMode==='view'"
                    items="Y:Y - 顯示,N:N - 隱藏"
                    placeholder="">
        </g-combobox>

        <g-textbox label="員工編號"
                   x-model="formRecord.EMPLOYEE_ID"
                   x-bind-readonly="recordMode==='view'">
        </g-textbox>

        <g-textbox label="程式型態"
                   x-model="formRecord.PROGRAM_TYPE"
                   x-bind-readonly="recordMode==='view'">
        </g-textbox>

        <g-textbox label="用途"
                   x-model="formRecord.PURPOSE"
                   x-bind-readonly="recordMode==='view'"
                   wrapper-class="flex flex-col gap-1 md:col-span-2">
        </g-textbox>

        <g-textbox label="預計開發開始日"
                   type="date"
                   x-model="formRecord.PLAN_START_DEVELOP_DATE"
                   x-bind-readonly="recordMode==='view'">
        </g-textbox>

        <g-textbox label="實際開發開始日"
                   type="date"
                   x-model="formRecord.REAL_START_DEVELOP_DATE"
                   x-bind-readonly="recordMode==='view'">
        </g-textbox>

        <g-textbox label="預計開發完工日"
                   type="date"
                   x-model="formRecord.PLAN_FINISH_DEVELOP_DATE"
                   x-bind-readonly="recordMode==='view'">
        </g-textbox>

        <g-textbox label="實際開發完工日"
                   type="date"
                   x-model="formRecord.REAL_FINISH_DEVELOP_DATE"
                   x-bind-readonly="recordMode==='view'">
        </g-textbox>

        <g-textbox label="預計工時"
                   type="number"
                   step="0.1"
                   x-model="formRecord.PLAN_WORK_HOURS"
                   x-bind-readonly="recordMode==='view'"
                   extra-class="text-right">
        </g-textbox>

        <g-textbox label="實際工時"
                   type="number"
                   step="0.1"
                   x-model="formRecord.REAL_WORK_HOURS"
                   x-bind-readonly="recordMode==='view'"
                   extra-class="text-right">
        </g-textbox>
    </div>

    <div class="flex justify-end gap-2 mt-5 pt-4 border-t border-slate-100">
        <g-button text="取消" icon="close" type="secondary" onclick="gDialogClose('dlgRecord')"></g-button>
        <g-button text="儲存" icon="save" type="success" x-show="recordMode!=='view'" onclick="window._idmApp?.saveRecord()"></g-button>
    </div>
</g-dialog>

<g-dialog id="dlgRoleRecord" title="角色功能維護" width="md">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <g-textbox label="角色代號"
                   x-model="roleRecord.ROLE_NO"
                   x-bind-readonly="roleMode==='view'">
        </g-textbox>
        <g-textbox label="角色名稱"
                   x-model="roleRecord.ROLE_NAME"
                   x-bind-readonly="roleMode==='view'">
        </g-textbox>
        <g-textbox label="功能編號"
                   x-model="roleRecord.FUNCTION_NO"
                   x-bind-readonly="roleMode==='view'">
        </g-textbox>
        <g-textbox label="序"
                   type="number"
                   x-model="roleRecord.DISPLAY_ORDER"
                   x-bind-readonly="roleMode==='view'">
        </g-textbox>
        <g-textbox label="顏色"
                   x-model="roleRecord.DISPLAY_COLOR"
                   x-bind-readonly="roleMode==='view'">
        </g-textbox>
    </div>
    <div class="flex justify-end gap-2 mt-5 pt-4 border-t border-slate-100">
        <g-button text="取消" icon="close" type="secondary" onclick="gDialogClose('dlgRoleRecord')"></g-button>
        <g-button text="儲存" icon="save" type="success" x-show="roleMode!=='view'" onclick="window._idmApp?.saveRoleRecord()"></g-button>
    </div>
</g-dialog>

</div>

@section Scripts {
    <g-js profile="popup" include-alpine="true" alpine-version="3.x.x"></g-js>
    <script>
        function toDateInput(v) {
            if (!v) return '';
            const s = String(v);
            return s.length >= 10 ? s.slice(0, 10) : '';
        }

        document.addEventListener('alpine:init', () => {
            Alpine.data('idmgd01App', () => ({
                search: { programNo: '', employeeId: '', displayCode: 'Y' },
                programs: [],
                selectedProgram: null,
                recordMode: 'view', // view | edit | create
                formRecord: {},
                roleMode: 'view', // view | edit | create
                roleRecord: {},
                rolePosition: 1,

                init() {
                    window._idmApp = this;
                    window.idmOpenCreate = () => window._idmApp?.openCreate();
                    window.idmViewRecord = (row) => window._idmApp?.viewRecord(row);
                    window.idmEditRecord = (row) => window._idmApp?.editRecord(row);
                    window.idmSelectProgram = (row) => window._idmApp?.selectProgram(row);
                    window.idmAddRole1 = () => window._idmApp?.openRoleCreate(1);
                    window.idmAddRole2 = () => window._idmApp?.openRoleCreate(2);
                    window.idmAddRole3 = () => window._idmApp?.openRoleCreate(3);
                    window.idmEditRole1 = (row) => window._idmApp?.editRoleRecord(row, 1);
                    window.idmEditRole2 = (row) => window._idmApp?.editRoleRecord(row, 2);
                    window.idmEditRole3 = (row) => window._idmApp?.editRoleRecord(row, 3);
                    window.idmDeleteRole = (row) => window._idmApp?.deleteRoleRecord(row);
                    console.log('[IDMGD01] app initialized');
                    this.executeQuery();
                },

                showToast(msg, type = 'success') { gToast(msg, type); },

                normalizeRecord(row) {
                    return {
                        ...row,
                        PROGRAM_NO: row?.PROGRAM_NO ?? '',
                        DISPLAY_CODE: row?.DISPLAY_CODE ?? 'Y',
                        EMPLOYEE_ID: row?.EMPLOYEE_ID ?? '',
                        PURPOSE: row?.PURPOSE ?? '',
                        PROGRAM_TYPE: row?.PROGRAM_TYPE ?? '',
                        PLAN_START_DEVELOP_DATE: toDateInput(row?.PLAN_START_DEVELOP_DATE),
                        PLAN_FINISH_DEVELOP_DATE: toDateInput(row?.PLAN_FINISH_DEVELOP_DATE),
                        REAL_START_DEVELOP_DATE: toDateInput(row?.REAL_START_DEVELOP_DATE),
                        REAL_FINISH_DEVELOP_DATE: toDateInput(row?.REAL_FINISH_DEVELOP_DATE),
                        PLAN_WORK_HOURS: row?.PLAN_WORK_HOURS ?? '',
                        REAL_WORK_HOURS: row?.REAL_WORK_HOURS ?? ''
                    };
                },

                async executeQuery() {
                    this.search.employeeId = document.getElementById('searchEmployeeId')?.value ?? this.search.employeeId;
                    await this.executeQueryFromGrid({});
                },

                async executeQueryFromGrid(filters) {
                    try {
                        const grid = document.getElementById('idmGrid')?.gDataGrid;
                        if (!grid) return;
                        const query = {
                            programNo: this.search.programNo,
                            employeeId: this.search.employeeId,
                            displayCode: this.search.displayCode,
                            ...(filters || {})
                        };
                        await grid.fetchData(query);
                        this.programs = grid.rows || [];
                        if (this.programs.length > 0) {
                            this.selectProgram(this.programs[0]);
                        } else {
                            this.selectedProgram = null;
                            await this.reloadRoleGrids();
                        }
                    } catch (e) {
                        this.showToast('查詢失敗: ' + e, 'error');
                    }
                },

                selectProgram(row) {
                    this.selectedProgram = row ? JSON.parse(JSON.stringify(row)) : null;
                    this.reloadRoleGrids();
                },

                async reloadRoleGrids() {
                    const programId = this.selectedProgram?.PROGRAM_ID;
                    const grids = [
                        { id: 'roleGrid1', pos: 1 },
                        { id: 'roleGrid2', pos: 2 },
                        { id: 'roleGrid3', pos: 3 }
                    ];

                    for (const g of grids) {
                        const grid = document.getElementById(g.id)?.gDataGrid;
                        if (!grid) continue;
                        await grid.fetchData(programId ? { programId } : { programId: '' });
                    }
                },

                normalizeRoleRecord(row) {
                    return {
                        ROWID: row?.ROWID ?? '',
                        ROLE_FUNCTION_ID: row?.ROLE_FUNCTION_ID ?? '',
                        PROGRAM_ID: row?.PROGRAM_ID ?? this.selectedProgram?.PROGRAM_ID ?? '',
                        POSITION_NO: row?.POSITION_NO ?? this.rolePosition,
                        ROLE_ID: row?.ROLE_ID ?? '',
                        ROLE_NO: row?.ROLE_NO ?? '',
                        ROLE_NAME: row?.ROLE_NAME ?? '',
                        FUNCTION_NO: row?.FUNCTION_NO ?? '',
                        DISPLAY_ORDER: row?.DISPLAY_ORDER ?? '',
                        DISPLAY_COLOR: row?.DISPLAY_COLOR ?? ''
                    };
                },

                openRoleCreate(positionNo) {
                    if (!this.selectedProgram?.PROGRAM_ID) {
                        this.showToast('請先選擇一筆程式資料', 'warning');
                        return;
                    }
                    this.roleMode = 'create';
                    this.rolePosition = positionNo;
                    this.roleRecord = this.normalizeRoleRecord({ POSITION_NO: positionNo });
                    gDialogOpen('dlgRoleRecord');
                },

                editRoleRecord(row, positionNo) {
                    this.roleMode = 'edit';
                    this.rolePosition = positionNo ?? row?.POSITION_NO ?? 1;
                    this.roleRecord = this.normalizeRoleRecord(row);
                    gDialogOpen('dlgRoleRecord');
                },

                async deleteRoleRecord(row) {
                    const ok = await gConfirm(`確定刪除角色 ${row?.ROLE_NO || ''} / 功能 ${row?.FUNCTION_NO || ''}？`, '刪除確認');
                    if (!ok) return;
                    try {
                        const res = await fetch('/Idm/deleteRoleFunctionProgram?DataMember=IDMGD01', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(row || {})
                        });
                        const result = await res.json();
                        if (!res.ok || result.status !== 'success') {
                            this.showToast('刪除失敗: ' + (result.message || res.statusText), 'error');
                            return;
                        }
                        this.showToast('刪除成功', 'success');
                        await this.reloadRoleGrids();
                    } catch (e) {
                        this.showToast('刪除失敗: ' + e, 'error');
                    }
                },

                async saveRoleRecord() {
                    if (!this.selectedProgram?.PROGRAM_ID) {
                        this.showToast('請先選擇一筆程式資料', 'warning');
                        return;
                    }
                    const payload = {
                        ...this.roleRecord,
                        PROGRAM_ID: this.selectedProgram.PROGRAM_ID,
                        POSITION_NO: this.rolePosition
                    };
                    if (!payload.ROLE_NO) {
                        this.showToast('角色代號為必填', 'warning');
                        return;
                    }
                    try {
                        const res = await fetch('/Idm/upsertRoleFunctionProgram?DataMember=IDMGD01', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        const result = await res.json();
                        if (!res.ok || result.status !== 'success') {
                            this.showToast('儲存失敗: ' + (result.message || res.statusText), 'error');
                            return;
                        }
                        gDialogClose('dlgRoleRecord');
                        this.showToast(this.roleMode === 'create' ? '新增成功' : '更新成功', 'success');
                        await this.reloadRoleGrids();
                    } catch (e) {
                        this.showToast('儲存失敗: ' + e, 'error');
                    }
                },

                openCreate() {
                    this.recordMode = 'create';
                    this.formRecord = this.normalizeRecord({ DISPLAY_CODE: 'Y' });
                    gDialogOpen('dlgRecord');
                },
                viewRecord(row) {
                    console.log('[IDMGD01] viewRecord()', row);
                    this.recordMode = 'view';
                    this.formRecord = this.normalizeRecord(JSON.parse(JSON.stringify(row)));
                    gDialogOpen('dlgRecord');
                },
                editRecord(row) {
                    console.log('[IDMGD01] editRecord()', row);
                    this.recordMode = 'edit';
                    this.formRecord = this.normalizeRecord(JSON.parse(JSON.stringify(row)));
                    gDialogOpen('dlgRecord');
                },

                async saveRecord() {
                    const payload = { ...this.formRecord };
                    if (!payload.PROGRAM_NO) {
                        this.showToast('程式編號為必填', 'warning');
                        return;
                    }

                    try {
                        const isCreate = this.recordMode === 'create';
                        const api = isCreate ? '/Idm/insert?DataMember=IDMGD01' : '/Idm/update?DataMember=IDMGD01';
                        const res = await fetch(api, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        const result = await res.json();
                        if (!res.ok || result.status !== 'success') {
                            this.showToast('儲存失敗: ' + (result.message || res.statusText), 'error');
                            return;
                        }

                        gDialogClose('dlgRecord');
                        this.showToast(isCreate ? '新增成功' : '更新成功', 'success');
                        await this.executeQuery();
                    } catch (e) {
                        this.showToast('儲存失敗: ' + e, 'error');
                    }
                },

                async confirmDelete(row) {
                    const ok = await gConfirm(`確定刪除程式 ${row.PROGRAM_NO}？\n此操作無法還原。`, '刪除確認');
                    if (!ok) return;
                    try {
                        const res = await fetch('/Idm/delete?DataMember=IDMGD01', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(row)
                        });
                        const result = await res.json();
                        if (!res.ok || result.status !== 'success') {
                            this.showToast('刪除失敗: ' + (result.message || res.statusText), 'error');
                            return;
                        }
                        this.showToast('刪除成功', 'success');
                        await this.executeQuery();
                    } catch (e) {
                        this.showToast('刪除失敗: ' + e, 'error');
                    }
                }
            }));
        });
    </script>
}
