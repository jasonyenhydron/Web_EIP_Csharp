@model dynamic

@{
    ViewData["Title"] = "IDMGD01 - 程式資料維護";
    Layout = "~/Views/Shared/_PopupLayout.cshtml";
}

<div class="px-4 py-8 max-w-7xl mx-auto" x-data="idmgd01App()">
    <!-- Top Header & Search Area -->
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 mb-6 p-4 flex flex-wrap items-end gap-4">
        <div class="space-y-1">
            <label class="block text-xs font-bold text-slate-700">程式編號</label>
            <input type="text" x-model="search.programNo" class="block w-40 px-3 py-2 border border-slate-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500 uppercase">
        </div>

        <div class="space-y-1">
            <label class="block text-xs font-bold text-slate-700">員工編號</label>
            <div class="flex rounded-md shadow-sm">
                <input type="hidden" id="searchEmployeeId" x-model="search.employeeId">
                <input type="text" id="searchEmployeeNo" class="w-24 block px-3 py-2 rounded-none rounded-l-md border border-slate-300 focus:ring-blue-500 focus:border-blue-500 sm:text-sm text-blue-700 font-bold bg-blue-50 hover:bg-blue-100 cursor-pointer transition-colors" readonly placeholder="員工" @@click="openSearchEmployeeLov()">
                <input type="text" id="searchEmployeeName" class="w-32 block px-3 py-2 rounded-none rounded-r-md border-y border-r border-slate-300 bg-slate-50 text-slate-600 sm:text-sm cursor-pointer hover:bg-slate-100 transition-colors" readonly @@click="openSearchEmployeeLov()">
            </div>
        </div>

        <div class="space-y-1">
            <label class="block text-xs font-bold text-slate-700">顯示碼</label>
            <select x-model="search.displayCode" class="block w-24 px-3 py-2 border border-slate-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500">
                <option value="">全部</option>
                <option value="Y">Y</option>
                <option value="N">N</option>
            </select>
        </div>

        <button type="button" @@click="executeQuery()" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-md shadow-sm text-sm transition-colors flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            Query
        </button>
    </div>

    <!-- Tabs Container -->
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden min-h-[500px] flex flex-col">

        <!-- Tab Headers -->
        <div class="flex border-b border-slate-200 bg-slate-50 px-2 pt-2 gap-1">
            <button @@click="activeTab = 'list'" :class="activeTab === 'list' ? 'bg-white border-t border-x border-slate-200 text-blue-700 font-bold translate-y-px' : 'bg-transparent text-slate-600 hover:bg-slate-100 border-transparent'" class="px-6 py-2.5 text-sm rounded-t-md border transition-colors relative z-10">
                程式資料
            </button>
            <button @@click="activeTab = 'detail'" :class="activeTab === 'detail' ? 'bg-white border-t border-x border-slate-200 text-blue-700 font-bold translate-y-px' : 'bg-transparent text-slate-600 hover:bg-slate-100 border-transparent'" class="px-6 py-2.5 text-sm rounded-t-md border transition-colors relative z-10">
                程式詳細資料
            </button>
            <button @@click="activeTab = 'maintenance'" :class="activeTab === 'maintenance' ? 'bg-white border-t border-x border-slate-200 text-blue-700 font-bold translate-y-px' : 'bg-transparent text-slate-600 hover:bg-slate-100 border-transparent'" class="px-6 py-2.5 text-sm rounded-t-md border transition-colors relative z-10">
                程式維護
            </button>
        </div>

        <!-- Tab 1: 程式資料 (List) -->
        <div x-show="activeTab === 'list'" class="flex-1 p-0 overflow-auto">
            <table class="min-w-full divide-y divide-slate-200 border-b border-slate-200">
                <thead class="bg-slate-50 sticky top-0 shadow-sm z-10">
                    <tr>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider border-r border-slate-200">程式編號</th>
                        <th class="px-3 py-3 text-center text-xs font-medium text-slate-500 uppercase tracking-wider border-r border-slate-200 w-16">顯示</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider border-r border-slate-200">員工編號</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider border-r border-slate-200">用途</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider border-r border-slate-200">程式型態</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">建檔日期</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-slate-200 cursor-pointer">
                    <template x-for="item in programs" :key="item.ROWID">
                        <tr @@click="selectRecord(item)" class="hover:bg-blue-50 transition-colors" :class="{'bg-blue-100/50': selectedRecord && selectedRecord.ROWID === item.ROWID}">
                            <td class="px-4 py-2 text-sm font-bold text-blue-600 border-r border-slate-100" x-text="item.PROGRAM_NO"></td>
                            <td class="px-3 py-2 text-sm text-center border-r border-slate-100" x-text="item.DISPLAY_CODE"></td>
                            <td class="px-4 py-2 text-sm text-slate-600 border-r border-slate-100" x-text="item.EMPLOYEE_ID"></td>
                            <td class="px-4 py-2 text-sm text-slate-800 border-r border-slate-100 truncate max-w-xs" x-text="item.PURPOSE"></td>
                            <td class="px-4 py-2 text-sm text-slate-600 border-r border-slate-100" x-text="item.PROGRAM_TYPE"></td>
                            <td class="px-4 py-2 text-sm text-slate-500" x-text="formatDate(item.ENTRY_DATE)"></td>
                        </tr>
                    </template>
                    <tr x-show="programs.length === 0">
                        <td colspan="6" class="px-4 py-8 text-center text-slate-400 text-sm">無資料 (No data)</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Tab 2: 程式詳細資料 (Detail) -->
        <div x-show="activeTab === 'detail'" class="flex-1 p-6 bg-slate-50/50">
            <div x-show="!selectedRecord" class="h-full flex items-center justify-center text-slate-400">
                請先從列表中選擇一筆資料
            </div>

            <div x-show="selectedRecord" class="max-w-4xl mx-auto space-y-6">
                <!-- Action Buttons -->
                <div class="flex items-center gap-2 justify-end mb-4 bg-white p-2 rounded-md shadow-sm border border-slate-200">
                    <div class="text-sm font-bold text-slate-500 mr-auto flex-1 bg-yellow-100 px-3 py-1.5 rounded" x-text="'程式編號: ' + (selectedRecord?.PROGRAM_NO || '')"></div>
                    <button class="px-3 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm rounded transition-colors">&lt;</button>
                    <button class="px-3 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-600 text-sm rounded transition-colors">&gt;</button>
                </div>

                <!-- Form Card -->
                <div class="bg-white p-6 rounded-lg shadow-sm border border-slate-200">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-5">
                        <div class="space-y-1">
                            <label class="block text-xs font-bold text-slate-700">顯示碼</label>
                            <input type="text" x-model="selectedRecord.DISPLAY_CODE" class="block w-24 px-3 py-2 border border-slate-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500 uppercase">
                        </div>

                        <div class="col-span-2 grid grid-cols-2 gap-4">
                            <div class="space-y-1">
                                <label class="block text-xs font-bold text-slate-700">員工編號 / 姓名</label>
                                <div class="flex rounded-md shadow-sm">
                                    <input type="text" x-model="selectedRecord.EMPLOYEE_ID" class="w-1/3 block px-3 py-2 rounded-none rounded-l-md border border-slate-300 focus:ring-blue-500 focus:border-blue-500 sm:text-sm text-blue-700 font-bold bg-blue-50" readonly>
                                    <input type="text" class="w-2/3 block px-3 py-2 rounded-none rounded-r-md border-y border-r border-slate-300 bg-slate-50 text-slate-600 sm:text-sm" readonly placeholder="姓名">
                                </div>
                            </div>
                        </div>

                        <div class="space-y-1">
                            <label class="block text-xs font-bold text-slate-700">程式型態</label>
                            <input type="text" x-model="selectedRecord.PROGRAM_TYPE" class="block w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500">
                        </div>

                        <div class="space-y-1 md:col-span-2">
                            <label class="block text-xs font-bold text-slate-700">用途</label>
                            <input type="text" x-model="selectedRecord.PURPOSE" class="block w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500 bg-yellow-50">
                        </div>

                        <div class="space-y-1">
                            <label class="block text-xs font-bold text-slate-700 text-blue-600">預計開發開始日</label>
                            <input type="datetime-local" x-model="localFormattedPlanStart" class="block w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500">
                        </div>
                        <div class="space-y-1">
                            <label class="block text-xs font-bold text-slate-700 text-blue-600">實際開發開始日</label>
                            <input type="datetime-local" x-model="localFormattedRealStart" class="block w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500">
                        </div>

                        <div class="space-y-1">
                            <label class="block text-xs font-bold text-slate-700 text-blue-600">預計開發完工日</label>
                            <input type="datetime-local" x-model="localFormattedPlanFinish" class="block w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500">
                        </div>
                        <div class="space-y-1">
                            <label class="block text-xs font-bold text-slate-700 text-blue-600">實際開發完工日</label>
                            <input type="datetime-local" x-model="localFormattedRealFinish" class="block w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500">
                        </div>

                        <div class="space-y-1">
                            <label class="block text-xs font-bold text-slate-700 text-blue-600">預計工時</label>
                            <input type="number" x-model="selectedRecord.PLAN_WORK_HOURS" class="block w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500 text-right">
                        </div>
                        <div class="space-y-1">
                            <label class="block text-xs font-bold text-slate-700 text-blue-600">實際工時</label>
                            <input type="number" x-model="selectedRecord.REAL_WORK_HOURS" class="block w-full px-3 py-2 border border-slate-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500 text-right">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tab 3: 程式維護 (Maintenance) -->
        <div x-show="activeTab === 'maintenance'" class="flex-1 p-6 bg-slate-50/50 flex items-center justify-center">
             <div class="text-slate-400">目前暫無維護紀錄資料結構</div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script>
        // Bind external LOV target fields to Alpine component via interval or event
        function updateAlpineStateFromLov() {
            const empIdInput = document.getElementById('searchEmployeeId');
            if(empIdInput && window.currentAlpineInstance) {
                window.currentAlpineInstance.search.employeeId = empIdInput.value;
            }
        }

        // Global LOV triggers
        function openSearchEmployeeLov() {
            // Using the shared generic LOV function
            openGenericLov(
                '尋找員工 (Employee)',
                '/api/lov/hrm/employees',
                ['編號', '名稱', 'ID'],
                ['employee_no', 'employee_name', 'employee_id'],
                {
                    'employee_id': 'searchEmployeeId',
                    'employee_no': 'searchEmployeeNo',
                    'employee_name': 'searchEmployeeName'
                },
                null,
                updateAlpineStateFromLov // Call this when LOV confirms
            );
        }

        function toDateTimeLocal(isoString) {
            if (!isoString) return '';
            // Oracle DATE returns something like "2023-01-01T00:00:00" in JSON depending on serializer
            try {
                const date = new Date(isoString);
                const offset = date.getTimezoneOffset() * 60000;
                const localISOTime = (new Date(date - offset)).toISOString().slice(0, 16);
                return localISOTime;
            } catch(e) {
                return '';
            }
        }

        document.addEventListener('alpine:init', () => {
            Alpine.data('idmgd01App', () => ({
                activeTab: 'list', // list, detail, maintenance
                search: {
                    programNo: '',
                    employeeId: '',
                    displayCode: 'Y'
                },
                programs: [],
                selectedRecord: null,

                init() {
                    window.currentAlpineInstance = this;
                    this.executeQuery();
                },

                get localFormattedPlanStart() { return toDateTimeLocal(this.selectedRecord?.PLAN_START_DEVELOP_DATE); },
                set localFormattedPlanStart(val) { if(this.selectedRecord) this.selectedRecord.PLAN_START_DEVELOP_DATE = val; },

                get localFormattedRealStart() { return toDateTimeLocal(this.selectedRecord?.REAL_START_DEVELOP_DATE); },
                set localFormattedRealStart(val) { if(this.selectedRecord) this.selectedRecord.REAL_START_DEVELOP_DATE = val; },

                get localFormattedPlanFinish() { return toDateTimeLocal(this.selectedRecord?.PLAN_FINISH_DEVELOP_DATE); },
                set localFormattedPlanFinish(val) { if(this.selectedRecord) this.selectedRecord.PLAN_FINISH_DEVELOP_DATE = val; },

                get localFormattedRealFinish() { return toDateTimeLocal(this.selectedRecord?.REAL_FINISH_DEVELOP_DATE); },
                set localFormattedRealFinish(val) { if(this.selectedRecord) this.selectedRecord.REAL_FINISH_DEVELOP_DATE = val; },


                formatDate(isoString) {
                    if (!isoString) return '';
                    return new Date(isoString).toLocaleString('zh-TW', {
                        year: 'numeric', month: '2-digit', day: '2-digit',
                        hour: '2-digit', minute:'2-digit'
                    });
                },

                async executeQuery() {
                    try {
                        // Force update employeeId if set by LOV
                        this.search.employeeId = document.getElementById('searchEmployeeId').value;

                        const params = new URLSearchParams({
                            programNo: this.search.programNo,
                            employeeId: this.search.employeeId,
                            displayCode: this.search.displayCode
                        });

                        const response = await fetch('/api/mis/programs/IDMGD01/list?' + params.toString());
                        const result = await response.json();

                        if (result.status === 'success') {
                            this.programs = result.data;
                            if(this.selectedRecord) {
                                // check if selected still exists
                                const exists = this.programs.find(p => p.ROWID === this.selectedRecord.ROWID);
                                if(!exists) this.selectedRecord = null;
                            }
                        } else {
                            alert('Query error: ' + result.message);
                        }
                    } catch (e) {
                        alert('Query failed: ' + e);
                    }
                },

                selectRecord(item) {
                    this.selectedRecord = JSON.parse(JSON.stringify(item)); // simple clone for editing
                    this.activeTab = 'detail';
                }
            }));
        });
    </script>
}
