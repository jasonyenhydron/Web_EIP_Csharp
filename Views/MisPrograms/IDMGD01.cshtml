@{
    ViewData["Title"] = ViewBag.ProgramTitle ?? System.IO.Path.GetFileNameWithoutExtension(ViewContext.ExecutingFilePath);
    ViewData["HidePopupFooterClose"] = false;
    ViewData["PopupFullscreenTargetId"] = "idmgRootPanel";
    Layout = "~/Views/Shared/_PopupLayout.cshtml";
    var employeeLov = ViewBag.EmployeeLov as Web_EIP_Csharp.Models.Lov.LovInputConfig ?? new();
    var employeeLovTitleJson = System.Text.Json.JsonSerializer.Serialize(employeeLov.Title);
    var employeeLovApiJson = System.Text.Json.JsonSerializer.Serialize(employeeLov.Api);
    var employeeLovColumnsJson = System.Text.Json.JsonSerializer.Serialize(employeeLov.Columns);
    var employeeLovFieldsJson = System.Text.Json.JsonSerializer.Serialize(employeeLov.Fields);
}

@section Styles {
    <g-style profile="datagrid"></g-style>
}

<div class="absolute inset-0 p-0 idmg-shell overflow-hidden" x-data="idmgd01App()" x-init="init()">
<div id="idmgRootPanel" class="idmg-panel flex flex-col h-full min-h-0 overflow-y-auto overflow-x-hidden">

    <div class="flex flex-col flex-1 min-h-0">
        <g-datagrid id="idmGrid"
                    api="/Idm/select?DataMember=IDMGD01"
                    columns="PROGRAM_NO:程式編號:150:left,EMPLOYEE_ID:員工:120:left,DISPLAY_CODE:顯示碼:80:center"
                    query-columns='[
                        {"FieldName":"programNo","Caption":"程式編號","Condition":"%","DataType":"string","Editor":"gtext","Span":3},
                        {"FieldName":"employeeId","Caption":"員工編號","Condition":"=","DataType":"string","Editor":"lovinput","LovTitle":@Html.Raw(employeeLovTitleJson),"LovApi":@Html.Raw(employeeLovApiJson),"LovColumns":@Html.Raw(employeeLovColumnsJson),"LovFields":@Html.Raw(employeeLovFieldsJson),"LovKeyValue":"employee_id","LovKeyDisplay":"employee_name","LovDisplayFormat":"{employee_id}-{employee_name}","Span":3},
                        {"FieldName":"displayCode","Caption":"顯示碼","Condition":"=","DataType":"string","Editor":"infocombobox","EditorOptions":"Y=是;N=否","Span":2}
                    ]'
                    form-columns='[
                        {"FieldName":"PROGRAM_NO","Caption":"程式編號","ColumnType":"gtext","Required":true,"IsPrimaryKey":true,"Placeholder":"例：IDMGD99"},
                        {"FieldName":"DISPLAY_CODE","Caption":"顯示碼","ColumnType":"gcombobox","Options":"Y:Y - 顯示,N:N - 隱藏"},
                        {"FieldName":"EMPLOYEE_ID","Caption":"員工編號","ColumnType":"lovinput","LovTitle":@Html.Raw(employeeLovTitleJson),"LovApi":@Html.Raw(employeeLovApiJson),"LovColumns":@Html.Raw(employeeLovColumnsJson),"LovFields":@Html.Raw(employeeLovFieldsJson),"LovKeyValue":"employee_id","LovKeyDisplay":"employee_name","LovDisplayFormat":"{employee_id}-{employee_name}"},
                        {"FieldName":"PROGRAM_TYPE","Caption":"程式型態","ColumnType":"gtext"},
                        {"FieldName":"PURPOSE","Caption":"用途","ColumnType":"gtext","ColSpan":2},
                        {"FieldName":"PLAN_START_DEVELOP_DATE","Caption":"預計開發開始日","ColumnType":"date"},
                        {"FieldName":"REAL_START_DEVELOP_DATE","Caption":"實際開發開始日","ColumnType":"date"},
                        {"FieldName":"PLAN_FINISH_DEVELOP_DATE","Caption":"預計開發完工日","ColumnType":"date"},
                        {"FieldName":"REAL_FINISH_DEVELOP_DATE","Caption":"實際開發完工日","ColumnType":"date"},
                        {"FieldName":"PLAN_WORK_HOURS","Caption":"預計工時","ColumnType":"number"},
                        {"FieldName":"REAL_WORK_HOURS","Caption":"實際工時","ColumnType":"number"}
                    ]'
                    pagination="true"
                    page-list="20,50,100"
                    page-size="20"
                    always-close="false"
                    not-init-grid="true"
                    row-numbers="true"
                    edit-mode="form"
                    query-auto-column="false"
                    allow-add="true"
                    allow-update="true"
                    allow-delete="true"
                    view-command-visible="true"
                    on-load-success="idmGridLoaded"
                    on-row-click="idmSelectProgram"
                    @@delete="document.getElementById('idmGrid')?.gDataGrid?.confirmDelete($event.detail.row, { confirmMessage: () => `確定刪除程式 ${$event.detail.row?.PROGRAM_NO || ''}？\n此操作無法還原。`, url: '/Idm/delete?DataMember=IDMGD01' })"
                    extra-class="flex-1 min-h-0 max-h-[52vh]"
                    clean-style="false"></g-datagrid>

        <div class="idmg-block rounded-none border-x-0 border-t px-3 py-2 text-sm text-slate-700">
            主檔：<span class="font-semibold" x-text="selectedProgram?.PROGRAM_NO || '-'"></span>
            <span class="text-slate-400 ml-2" x-text="selectedProgram?.PURPOSE || '請先點選上方程式資料'"></span>
        </div>

    </div>

</div>
</div>

@section Scripts {
    <g-js profile="datagrid"
          include-alpine="true"
          alpine-version="3.x.x"
          include-htmx="true"
          htmx-version="1.9.12"
          extras="https://unpkg.com/htmx.org/dist/ext/json-enc.js"></g-js>
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('idmgd01App', () => ({
                programs: [],
                selectedProgram: null,

                init() {
                    window.gDataGridRuntime?.registerAppCallbacks(this, {
                        appKey: '_idmApp',
                        callbacks: {
                            idmSelectProgram: 'selectProgram',
                            idmGridLoaded: 'onGridLoaded'
                        }
                    });
                    this.executeQuery();
                },

                async executeQuery() {
                    await window.gDataGridRuntime?.executeGridQuery('idmGrid');
                },

                async onGridLoaded(rows) {
                    this.programs = rows || [];
                    this.selectedProgram = this.programs.length > 0
                        ? window.gDataGridRuntime?.cloneData(this.programs[0], null)
                        : null;
                },

                selectProgram(row) {
                    this.selectedProgram = row
                        ? window.gDataGridRuntime?.cloneData(row, null)
                        : null;
                }
            }));
        });
    </script>
}
