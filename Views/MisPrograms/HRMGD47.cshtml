@{
    ViewData["Title"] = "HRMGD47 請假申請作業";
    Layout = "~/Views/Shared/_PopupLayout.cshtml";
}

<div class="min-h-screen bg-slate-50 py-6 px-4 sm:px-6 lg:px-8 font-sans">
    <div class="max-w-7xl mx-auto space-y-6">

        <!-- ======================= 頁首資訊快取 ======================= -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200/60 p-5 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 animate-fade-in-up">
            <div class="flex items-center gap-3">
                <div class="bg-gradient-to-br from-blue-500 to-indigo-600 p-2.5 rounded-xl shadow-lg shadow-blue-500/30 text-white">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                </div>
                <div>
                    <h1 class="text-xl font-extrabold text-slate-800 tracking-tight">HRMGD47 請假申請作業</h1>
                    <p class="text-xs text-slate-500 font-medium mt-0.5">永勝光學 ERP / 人資管理系統</p>
                </div>
            </div>
            <div class="flex flex-wrap items-center gap-3 text-xs font-medium text-slate-500 bg-slate-100/80 px-4 py-2 rounded-lg border border-slate-200">
                <span class="flex items-center gap-1"><svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg> 使用者: @ViewBag.UserId @ViewBag.UserName</span>
                <span class="text-slate-300">|</span>
                <span class="flex items-center gap-1"><svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg> 日期: @DateTime.Now.ToString("yyyy-MM-dd")</span>
            </div>
        </div>

        <!-- ======================= 查詢條件區 ======================= -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200/60 overflow-hidden animate-fade-in-up" style="animation-delay: 50ms;">
            <div class="bg-slate-50/80 px-5 py-3 border-b border-slate-100 flex items-center justify-between">
                <h2 class="text-sm font-bold text-slate-700 flex items-center gap-2">
                    <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    查詢條件 (過濾部門)
                </h2>
                <div class="flex items-center gap-2">
                    <button type="button" class="inline-flex items-center justify-center px-4 py-1.5 border border-transparent text-xs font-bold rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all">
                        查詢部門
                    </button>
                    <button type="button" class="inline-flex items-center justify-center px-4 py-1.5 border border-slate-300 text-xs font-bold rounded-md shadow-sm text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all">
                        進階查詢
                    </button>
                </div>
            </div>

            <div class="p-5 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 text-sm">
                <!-- 規章 -->
                <div class="space-y-1">
                    <label class="block font-medium text-slate-700 text-xs">規章</label>
                    <div class="flex rounded-md shadow-sm">
                        <input type="text" value="TW01" class="flex-1 min-w-0 block w-full px-3 py-1.5 rounded-l-md border border-slate-300 bg-slate-50 text-slate-500 sm:text-sm focus:ring-indigo-500 focus:border-indigo-500" readonly>
                        <input type="text" value="台灣人事規章" class="flex-2 block w-full px-3 py-1.5 rounded-r-md border-y border-r border-slate-300 bg-slate-50 text-slate-500 sm:text-sm focus:ring-indigo-500 focus:border-indigo-500" readonly>
                    </div>
                </div>
                <!-- 員工編號 -->
                <div class="space-y-1">
                    <label class="block font-medium text-slate-700 text-xs">員工編號名稱</label>
                    <div class="flex rounded-md shadow-sm">
                        <input type="hidden" id="filterEmployeeId" value="@ViewBag.NumericUserId">
                        <input type="text" id="filterEmployeeNo" value="@ViewBag.UserId" class="flex-1 min-w-0 block w-full px-3 py-1.5 rounded-none rounded-l-md border border-slate-300 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm hover:bg-slate-50 cursor-pointer" readonly onclick="openEmployeeLov('filterEmployeeId', 'filterEmployeeNo', 'filterEmployeeName')">
                        <input type="text" id="filterEmployeeName" value="@ViewBag.UserName" class="flex-1 block w-full px-3 py-1.5 rounded-none rounded-r-md border-y border-r border-slate-300 bg-slate-50 text-slate-500 sm:text-sm hover:bg-slate-100 cursor-pointer" readonly onclick="openEmployeeLov('filterEmployeeId', 'filterEmployeeNo', 'filterEmployeeName')">
                    </div>
                </div>
                <!-- 部門編號 -->
                <div class="space-y-1 lg:col-span-2">
                    <label class="block font-medium text-slate-700 text-xs">部門編號 / 名稱</label>
                    <div class="flex rounded-md shadow-sm">
                        <input type="text" id="deptNo" class="flex-1 block w-full px-3 py-1.5 rounded-none rounded-l-md border border-slate-300 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="輸入部門編號" onclick="openDepartmentLov()">
                        <input type="text" id="deptName" class="flex-2 block w-full px-3 py-1.5 rounded-none rounded-r-md border-y border-r border-slate-300 bg-slate-50 sm:text-sm" readonly onclick="openDepartmentLov()">
                    </div>
                </div>
                <!-- 查詢時間 -->
                <div class="space-y-1 lg:col-span-2">
                    <label class="block font-medium text-slate-700 text-xs">查詢時間區間</label>
                    <div class="flex items-center gap-2">
                        <input type="date" class="block w-full px-3 py-1.5 border border-slate-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                        <span class="text-slate-400">至</span>
                        <input type="date" class="block w-full px-3 py-1.5 border border-slate-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                    </div>
                </div>
                <!-- Checkboxes -->
                <div class="space-y-2 lg:col-span-2 flex items-end pb-1 pb-1.5 gap-6">
                    <label class="inline-flex items-center">
                        <input type="checkbox" class="rounded border-slate-300 text-indigo-600 shadow-sm focus:border-indigo-300 focus:ring focus:ring-indigo-200 focus:ring-opacity-50 h-4 w-4">
                        <span class="ml-2 text-sm text-slate-600 font-medium">含已簽核資料</span>
                    </label>
                    <label class="inline-flex items-center">
                        <input type="checkbox" class="rounded border-slate-300 text-indigo-600 shadow-sm focus:border-indigo-300 focus:ring focus:ring-indigo-200 focus:ring-opacity-50 h-4 w-4">
                        <span class="ml-2 text-sm text-slate-600 font-medium">含子部門</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- ======================= 請假單明細 (核心操作區) ======================= -->
        <div class="bg-white rounded-2xl shadow-xl shadow-blue-900/5 border border-blue-100 overflow-hidden animate-fade-in-up md:col-span-2 relative" style="animation-delay: 100ms;">
            <!-- Decorative gradient line at top -->
            <div class="h-1.5 w-full bg-gradient-to-r from-blue-400 via-indigo-500 to-purple-500"></div>

            <div class="p-6 md:p-8 relative">
                <!-- Status Badge Absolute -->
                <div class="absolute top-6 right-6 flex items-center gap-2">
                    <span class="relative flex h-3 w-3">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-3 w-3 bg-amber-500"></span>
                    </span>
                    <span class="text-sm font-bold text-amber-600 bg-amber-50 px-3 py-1 rounded-full border border-amber-200">狀態: 00 鍵入中</span>
                </div>

                <h3 class="text-lg font-bold text-slate-800 mb-6 pb-2 border-b border-slate-100">請假表單資料</h3>

                <div class="grid grid-cols-1 md:grid-cols-6 gap-x-6 gap-y-5">

                    <!-- 員工資訊行 -->
                    <div class="md:col-span-1 space-y-1">
                        <label class="block text-xs font-bold text-slate-700">單號 ID</label>
                        <input type="text" class="block w-full px-3 py-2 border-none bg-slate-100 rounded-md text-sm text-slate-500 font-mono" readonly placeholder="自動產生">
                    </div>
                    <div class="md:col-span-3 space-y-1">
                        <label class="block text-xs font-bold text-slate-700">申請員工 <span class="text-red-500">*</span></label>
                        <div class="flex rounded-md shadow-sm">
                            <input type="hidden" id="employeeId" value="@ViewBag.NumericUserId">
                            <input type="text" id="employeeNo" value="@ViewBag.UserId" class="w-1/3 block px-3 py-2 rounded-none rounded-l-md border border-slate-300 focus:ring-blue-500 focus:border-blue-500 sm:text-sm text-blue-700 font-bold bg-blue-50 hover:bg-blue-100 cursor-pointer transition-colors" readonly placeholder="員工編號" onclick="openEmployeeLov('employeeId', 'employeeNo', 'employeeName')">
                            <input type="text" id="employeeName" value="@ViewBag.UserName" class="w-2/3 block px-3 py-2 rounded-none rounded-r-md border-y border-r border-slate-300 bg-slate-50 text-slate-600 sm:text-sm hover:bg-slate-100 cursor-pointer transition-colors" readonly onclick="openEmployeeLov('employeeId', 'employeeNo', 'employeeName')">
                        </div>
                    </div>
                    <div class="md:col-span-2 space-y-1">
                        <label class="block text-xs font-bold text-slate-700">假別 <span class="text-red-500">*</span></label>
                        <div class="flex rounded-md shadow-sm">
                            <input type="hidden" id="leaveId">
                            <input type="text" id="leaveTypeDisplay" class="flex-1 w-full px-3 py-2 rounded-none rounded-l-md border border-slate-300 focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-blue-50 text-blue-800 font-bold" readonly placeholder="請選擇假別" onclick="openLeaveTypeLov()">
                            <button type="button" class="px-3 py-2 rounded-none rounded-r-md border-y border-r border-slate-300 bg-slate-100 hover:bg-slate-200 text-slate-600 sm:text-sm transition-colors" onclick="openLeaveTypeLov()">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" /></svg>
                            </button>
                        </div>
                    </div>

                    <!-- 時間行 -->
                    <div class="md:col-span-3 space-y-1">
                        <label class="block text-xs font-bold text-slate-700">請假開始時間 <span class="text-red-500">*</span></label>
                        <div class="flex items-center gap-2">
                            <input type="datetime-local" id="startTime" class="block w-full px-3 py-2 border border-slate-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                            <span class="text-xs text-slate-400 bg-slate-100 px-2 py-2 rounded border border-slate-200">星期 _</span>
                        </div>
                    </div>
                    <div class="md:col-span-3 space-y-1">
                        <label class="block text-xs font-bold text-slate-700">請假結束時間 <span class="text-red-500">*</span></label>
                        <input type="datetime-local" id="endTime" class="block w-full px-3 py-2 border border-slate-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                    </div>

                    <!-- 時數與日數行 -->
                    <div class="md:col-span-2 space-y-1">
                        <label class="block text-xs font-bold text-slate-700">時數 / 日數</label>
                        <div class="flex rounded-md shadow-sm">
                            <input type="number" id="leaveHours" placeholder="時數" class="w-1/2 block px-3 py-2 rounded-none rounded-l-md border border-slate-300 focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-yellow-50 text-right">
                            <input type="number" id="leaveDays" placeholder="日數" class="w-1/2 block px-3 py-2 rounded-none rounded-r-md border-y border-r border-slate-300 bg-slate-100 text-slate-500 sm:text-sm text-right">
                        </div>
                    </div>
                    <div class="md:col-span-2 space-y-1">
                        <label class="block text-xs font-bold text-slate-700">刷卡日</label>
                        <input type="date" class="block w-full px-3 py-2 border border-slate-300 rounded-md shadow-sm bg-pink-50/50 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                    </div>
                    <div class="md:col-span-2 space-y-1">
                        <label class="block text-xs font-bold text-slate-700">代理人員工</label>
                        <div class="flex rounded-md shadow-sm">
                            <input type="hidden" id="agentEmployeeId">
                            <input type="text" id="agentEmployeeNo" placeholder="員工編號" class="w-1/3 block px-3 py-2 rounded-none rounded-l-md border border-slate-300 focus:ring-blue-500 focus:border-blue-500 sm:text-sm hover:bg-slate-50 cursor-pointer transition-colors" readonly onclick="openEmployeeLov('agentEmployeeId', 'agentEmployeeNo', 'agentEmployeeName')">
                            <input type="text" id="agentEmployeeName" placeholder="姓名" class="w-2/3 block px-3 py-2 rounded-none rounded-r-md border-y border-r border-slate-300 bg-cyan-50/30 sm:text-sm hover:bg-cyan-100/50 cursor-pointer transition-colors" readonly onclick="openEmployeeLov('agentEmployeeId', 'agentEmployeeNo', 'agentEmployeeName')">
                        </div>
                    </div>

                    <!-- 事由 -->
                    <div class="md:col-span-6 space-y-1 mt-2">
                        <label class="block text-xs font-bold text-slate-700">事由 <span class="text-red-500">*</span></label>
                        <textarea id="askForLeaveReason" rows="2" class="block w-full px-3 py-2 border border-slate-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm resize-none"></textarea>
                    </div>

                    <!-- 出差相關資訊 (Grouped with background) -->
                    <div class="md:col-span-6 bg-slate-50 rounded-xl p-4 border border-slate-200/60 mt-2 grid grid-cols-1 md:grid-cols-6 gap-4">
                        <div class="md:col-span-2 space-y-1">
                            <label class="block text-xs font-bold text-slate-600">公出地點</label>
                            <input type="text" id="destinationPlace" class="block w-full px-3 py-1.5 border border-slate-300 rounded-md shadow-sm bg-white focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                        </div>
                        <div class="md:col-span-2 space-y-1">
                            <label class="block text-xs font-bold text-slate-600">接洽對象</label>
                            <input type="text" id="talkingAbout" class="block w-full px-3 py-1.5 border border-slate-300 rounded-md shadow-sm bg-white focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                        </div>
                        <div class="md:col-span-2 space-y-1">
                            <label class="block text-xs font-bold text-slate-600">交通工具</label>
                            <div class="flex rounded-md shadow-sm">
                                <input type="text" class="w-1/3 block px-3 py-1.5 rounded-none rounded-l-md border border-slate-300 bg-slate-200/50 sm:text-sm">
                                <input type="text" class="w-2/3 block px-3 py-1.5 rounded-none rounded-r-md border-y border-r border-slate-300 bg-slate-200/50 sm:text-sm" readonly>
                            </div>
                        </div>
                        <div class="md:col-span-6 flex flex-wrap items-center gap-6 mt-1 border-t border-slate-200 pt-3">
                            <div class="flex items-center space-x-4 bg-white px-4 py-1.5 rounded border border-slate-200/60">
                                <label class="inline-flex items-center">
                                    <input type="radio" name="return_workplace" value="Y" class="h-4 w-4 text-blue-600 border-slate-300 focus:ring-blue-500">
                                    <span class="ml-2 text-xs font-medium text-slate-600">返回工作地點</span>
                                </label>
                                <label class="inline-flex items-center">
                                    <input type="radio" name="return_workplace" value="N" class="h-4 w-4 text-blue-600 border-slate-300 focus:ring-blue-500" checked>
                                    <span class="ml-2 text-xs font-medium text-slate-600">不返回工作地點</span>
                                </label>
                            </div>
                            <label class="inline-flex items-center">
                                <input type="checkbox" id="overseasYn" value="Y" class="h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500">
                                <span class="ml-2 text-xs font-medium text-slate-600">海外出差</span>
                            </label>
                        </div>
                    </div>

                    <!-- 時數統計 -->
                    <div class="md:col-span-6 grid grid-cols-2 md:grid-cols-4 gap-4 bg-teal-50/50 p-4 rounded-xl border border-teal-100">
                        <div class="space-y-1">
                            <label class="block text-[10px] font-bold text-teal-700 uppercase">年度可休時數</label>
                            <input type="text" class="block w-full px-2 py-1.5 border-none bg-teal-100/50 rounded text-teal-800 font-mono text-sm" readonly value="120.0">
                        </div>
                        <div class="space-y-1">
                            <label class="block text-[10px] font-bold text-teal-700 uppercase">年度已休時數(不含本次)</label>
                            <input type="text" class="block w-full px-2 py-1.5 border-none bg-teal-100/50 rounded text-teal-800 font-mono text-sm" readonly value="32.5">
                        </div>
                        <div class="space-y-1">
                            <label class="block text-[10px] font-bold text-teal-700 uppercase">本期可休時數</label>
                            <input type="text" class="block w-full px-2 py-1.5 border-none bg-teal-100/50 rounded text-teal-800 font-mono text-sm" readonly value="0.0">
                        </div>
                        <div class="space-y-1">
                            <label class="block text-[10px] font-bold text-teal-700 uppercase">本期已休時數(不含本次)</label>
                            <input type="text" class="block w-full px-2 py-1.5 border-none bg-teal-100/50 rounded text-teal-800 font-mono text-sm" readonly value="0.0">
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="mt-8 flex flex-wrap justify-center gap-4 pt-6 border-t border-slate-100">
                    <button type="button" id="btnSubmit" class="px-8 py-2.5 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-bold rounded-lg shadow-md shadow-blue-500/30 hover:shadow-lg hover:shadow-blue-500/40 transform hover:-translate-y-0.5 transition-all w-full sm:w-auto">
                        送出申請
                    </button>
                    <button type="button" class="px-8 py-2.5 bg-white border-2 border-slate-200 text-slate-600 font-bold rounded-lg hover:bg-slate-50 hover:border-slate-300 hover:text-red-500 transition-all w-full sm:w-auto">
                        刪除簽核
                    </button>
                    <button type="button" disabled class="px-8 py-2.5 bg-slate-100 border border-slate-200 text-slate-400 font-bold rounded-lg cursor-not-allowed w-full sm:w-auto">
                        不准後重申請
                    </button>
                </div>
            </div>
        </div>

        <!-- ======================= 下方綜合資訊區 (附件 / 年度特休 / 簽核歷程) ======================= -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 animate-fade-in-up" style="animation-delay: 150ms;">

            <!-- 左下：附件與年度特休查詢 -->
            <div class="space-y-6">
                <!-- 附件上傳區 -->
                <div class="bg-white rounded-2xl shadow-sm border border-slate-200/60 p-5">
                    <div class="flex justify-between items-end mb-4">
                        <div>
                            <h3 class="font-bold text-slate-800 flex items-center gap-2">
                                <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path></svg>
                                附件檔案
                            </h3>
                            <p class="text-xs text-red-500 mt-1 font-medium">使用說明：瀏覽 -> 存檔 -> 上傳檔案</p>
                        </div>
                        <div class="text-right">
                            <span class="text-xs text-slate-500">附件數量: <span class="font-bold text-indigo-600">0</span></span>
                            <div class="mt-1 text-[10px] text-slate-400">傳檔結果: -</div>
                        </div>
                    </div>

                    <div class="overflow-x-auto rounded-lg border border-slate-200">
                        <table class="min-w-full divide-y divide-slate-200 text-sm">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th scope="col" class="px-3 py-2 text-left text-xs font-medium text-slate-500 uppercase">序</th>
                                    <th scope="col" class="px-3 py-2 text-left text-xs font-medium text-slate-500 uppercase">原始檔名</th>
                                    <th scope="col" class="px-3 py-2 text-left text-xs font-medium text-slate-500 uppercase">檔案說明</th>
                                    <th scope="col" class="px-3 py-2 text-center text-xs font-medium text-slate-500 uppercase">操作</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-slate-100">
                                <!-- Empty Row for Upload -->
                                <tr class="hover:bg-slate-50">
                                    <td class="px-3 py-2 whitespace-nowrap text-slate-500 text-xs">1</td>
                                    <td class="px-3 py-2 whitespace-nowrap">
                                        <input type="file" class="block w-full text-xs text-slate-500 file:mr-2 file:py-1 file:px-2 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100 cursor-pointer">
                                    </td>
                                    <td class="px-3 py-2 whitespace-nowrap">
                                        <input type="text" class="block w-full px-2 py-1 border border-slate-300 rounded text-xs focus:ring-indigo-500 focus:border-indigo-500" placeholder="說明...">
                                    </td>
