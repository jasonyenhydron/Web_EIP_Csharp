<style>
    /* 微動畫定義 */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-fade-in-up {
        animation: fadeInUp 0.4s ease-out forwards;
        opacity: 0;
    }

    /* Input field customizations to look more like the oracle form but modern */
    input[readonly].object-not-editable {
        background-color: #f1f5f9 !important; /* Tailwind slate-100 */
        border-color: #e2e8f0;
        cursor: not-allowed;
    }
</style>

@section Scripts {
    <script>
        // LOV Variables
        let currentLovSelectedRow = null;
        let selectedLeaveId = null;
        let selectedLeaveName = null;

        document.addEventListener("DOMContentLoaded", function () {
            // Setup Search Input Enter Key for LOV
            document.getElementById('lovSearchInput').addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    fetchLovData();
                }
            });

            const btnSubmit = document.getElementById("btnSubmit");
            const statusBarMsg = document.getElementById("statusBarMsg");

            btnSubmit.addEventListener("click", async function () {
                // 1. 抓取欄位並基礎驗證
                const employeeId = document.getElementById("employeeId").value;
                const leaveId = document.getElementById("leaveId").value;
                const startTime = document.getElementById("startTime").value;
                const endTime = document.getElementById("endTime").value;
                const askForLeaveReason = document.getElementById("askForLeaveReason").value;

                if (!employeeId || !leaveId || !startTime || !endTime || !askForLeaveReason) {
                    alert("請填寫所有必填欄位 (*號標示)。");
                    statusBarMsg.value = "錯誤: 必填欄位未填寫完整。";
                    return;
                }

                if (new Date(startTime) >= new Date(endTime)) {
                    alert("結束時間必須大於開始時間！");
                    statusBarMsg.value = "錯誤: 時間區間無效。";
                    return;
                }

                // 2. 組成 payload 以符合 C# Model : HrmEmAskForLeave
                const payload = {
                    employeeId: parseInt(employeeId, 10),
                    leaveId: parseInt(leaveId, 10),
                    startTime: startTime,
                    endTime: endTime,
                    leaveHours: document.getElementById("leaveHours").value ? parseFloat(document.getElementById("leaveHours").value) : null,
                    leaveDays: document.getElementById("leaveDays").value ? parseFloat(document.getElementById("leaveDays").value) : null,
                    askForLeaveReason: askForLeaveReason,
                    agentEmployeeId: document.getElementById("agentEmployeeId").value ? parseInt(document.getElementById("agentEmployeeId").value, 10) : null,
                    destinationPlace: document.getElementById("destinationPlace").value || null,
                    talkingAbout: document.getElementById("talkingAbout").value || null,
                    returnYn: document.querySelector('input[name="return_workplace"]:checked')?.value || 'N',
                    overseasYn: document.getElementById("overseasYn").checked ? 'Y' : 'N'
                };

                // 3. 呼叫後端建立 POST
                try {
                    statusBarMsg.value = "資料庫寫入中...";
                    btnSubmit.disabled = true;
                    const originalText = btnSubmit.innerText;
                    btnSubmit.innerText = "傳送中...";

                    const response = await fetch('/api/mis/programs/HRMGD47/submit', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(payload)
                    });

                    const data = await response.json();

                    if (response.ok && data.status === 'success') {
                        statusBarMsg.value = `Success: ${data.message} (流水號: ${data.id})`;
                        Swal.fire ? Swal.fire('成功', `申請單建立成功！<br>單號：<b>${data.id}</b>`, 'success') : alert(`申請單建立成功！單號：${data.id}`);

                        // 將單號填入畫面
                        const statusBadge = document.querySelector('.bg-amber-50');
                        if (statusBadge) {
                            statusBadge.className = "text-sm font-bold text-emerald-600 bg-emerald-50 px-3 py-1 rounded-full border border-emerald-200";
                            statusBadge.innerHTML = `狀態: 92 核決中 (ID: ${data.id})`;
                        }
                    } else {
                        statusBarMsg.value = `Error: ${data.message || 'Validation failed.'}`;
                        console.error("Errors:", data.errors || data);
                        alert(`申請失敗：\n${data.message || '請確認欄位格式'}`);
                    }
                } catch (error) {
                    statusBarMsg.value = `Error: 系統例外錯誤。`;
                    console.error("Fetch Error:", error);
                    alert("系統發生錯誤，無法連線。");
                } finally {
                    btnSubmit.disabled = false;
                    btnSubmit.innerText = "送出申請";
                }
            });
        });

        // ---------------- LOV Logic using Shared Module ----------------
        function openLeaveTypeLov() {
            openGenericLov(
                '尋找假別 (Leave Type)',
                '/api/lov/hrm/leave-types',
                ['假別編號', '假別名稱'],
                ['leave_id', 'leave_name'],
                {
                    'leave_id': 'leaveId',
                    'FORMATTED_DISPLAY': 'leaveTypeDisplay'
                },
                function(data) { return `${data.leave_id} - ${data.leave_name}`; }
            );
        }

        function openEmployeeLov(targetId, targetNo, targetName) {
            openGenericLov(
                '尋找員工 (Employee)',
                '/api/lov/hrm/employees',
                ['編號', '名稱', 'ID'],
                ['employee_no', 'employee_name', 'employee_id'],
                {
                    'employee_id': targetId,
                    'employee_no': targetNo,
                    'employee_name': targetName
                }
            );
        }

        function openDepartmentLov() {
            const empId = document.getElementById('employeeId').value || '';
            const apiUrl = `/api/lov/hrm/booking-departments?employeeId=${empId}`;

            openGenericLov(
                '尋找預約部門 (Booking Department)',
                apiUrl,
                ['部門ID', '部門編號', '部門名稱'],
                ['department_id', 'department_no', 'department_name'],
                {
                    'department_no': 'deptNo',
                    'department_name': 'deptName'
                }
            );
        }
    </script>
}
