@{
    var _viewName = System.IO.Path.GetFileNameWithoutExtension(ViewContext.ExecutingFilePath);
    ViewData["Title"] = ViewBag.ProgramTitle ?? _viewName;
    ViewData["ShowPopupTitleBar"] = false;
    Layout = "~/Views/Shared/_PopupLayout.cshtml";
    var leaveTypeLovApi = (ViewBag.LeaveTypeLovApi?.ToString() ?? "/api/lov/hrm/leave-types");
    var employeeLovApi = (ViewBag.EmployeeLovApi?.ToString() ?? "/api/lov/hrm/employees");
    var bookingDeptLovApi = (ViewBag.BookingDeptLovApi?.ToString() ?? "/api/lov/hrm/booking-departments");
}

<div class="min-h-full p-0">
    <div class="w-full space-y-5">

        <!-- ====================== 查詢條件 ====================== -->
        <g-panel title="查詢條件（過濾部門）" icon="filter" collapsible="true">
            <div class=" grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">

                <!-- 規章（g-lov-input：唯讀顯示，無 lov-fn）-->
                <g-lov-input label="規章"
                             code-id="ruleCode"     code-value="TW01"     code-placeholder="規章碼" code-width="w-20"
                             name-id="ruleName"     name-value="台灣人事規章"
                             readonly="true">
                </g-lov-input>

                <!-- 員工編號名稱（g-lov-input）-->
                <g-lov-input label="員工編號名稱"
                             lov-name="hrmgd47-filter-employee"
                             name-value=""
                             lov-title="尋找員工 (Employee)"
                             lov-api="@employeeLovApi"
                             lov-columns="編號,名稱,ID"
                             lov-fields="employee_no,employee_name,employee_id"
                             lov-return-value-field="employee_id"
                             lov-return-display-field="employee_name"
                             lov-key-hidden="employee_id"
                             lov-key-code="employee_no"
                             lov-key-name="employee_name"
                             selectonly="false">
                </g-lov-input>

                <!-- 部門（g-lov-input：code 欄可輸入）-->
                <g-lov-input label="部門編號 / 名稱"
                             code-id="deptNo"   code-placeholder="輸入部門編號"
                             name-id="deptName"
                             lov-title="尋找預約部門"
                             lov-api="@bookingDeptLovApi"
                             lov-columns="部門ID,部門編號,部門名稱"
                             lov-fields="department_id,department_no,department_name"
                             lov-key-code="department_no"
                             lov-key-name="department_name"
                             readonly="false" selectonly="false"
                             col-span="2">
                </g-lov-input>

                <!-- 查詢時間 -->
                <g-textbox label="查詢開始日期" name="qDateFrom" type="date" col-span="1"></g-textbox>
                <g-textbox label="查詢結束日期" name="qDateTo"   type="date" col-span="1"></g-textbox>

                <!-- 選項 Checkboxes -->
                <div class="flex flex-col gap-1 lg:col-span-2">
                    <label class="text-xs font-semibold text-slate-600 text-xs font-semibold text-slate-600 opacity-0">選項</label>
                    <div class="flex items-center gap-6 h-9">
                        <label class="inline-flex items-center gap-2 cursor-pointer text-sm text-xs font-semibold text-slate-600">
                            <input type="checkbox" class="h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500">
                            含已簽核資料
                        </label>
                        <label class="inline-flex items-center gap-2 cursor-pointer text-sm text-xs font-semibold text-slate-600">
                            <input type="checkbox" class="h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500">
                            含子部門
                        </label>
                    </div>
                </div>
            </div>

            <!-- 查詢按鈕列 -->
            <div class="mt-4 pt-4 border-t border-slate-100 flex flex-wrap gap-2">
                <g-button text="查詢部門"  icon="search"  type="primary"></g-button>
                <g-button text="進階查詢"  icon="filter"  type="secondary"></g-button>
                <g-button text="清除條件"  icon="refresh" type="ghost"></g-button>
            </div>
        </g-panel>

        <!-- ====================== 請假表單 ====================== -->
        <g-tabs active-tab="0">

            <!-- Tab 1：請假申請 -->
            <g-tab title="請假申請" icon="edit">
                <div class="relative">

                    <!-- 狀態徽章（g-status-badge）-->
                    <div class="absolute top-0 right-0">
                        <g-status-badge code="00" label="鍵入中" color="amber"></g-status-badge>
                    </div>

                    <h3 class="text-base font-semibold text-slate-700 mb-5">請假表單資料</h3>

                    <div class="grid grid-cols-1 md:grid-cols-6 gap-x-5 gap-y-4">

                        <!-- 單號（唯讀）-->
                        <g-textbox label="單號 ID" name="leaveNo" type="text"
                                   placeholder="自動產生" readonly="true" col-span="1"></g-textbox>

                        <!-- 申請員工（g-lov-input）-->
                <g-lov-input label="申請員工" required="true"
                                     hidden-id="employeeId"  hidden-value="@ViewBag.NumericUserId"
                                     code-id="employeeNo"    code-value="@ViewBag.UserId"
                                     name-id="employeeName"  name-value="@ViewBag.UserName"
                                     lov-title="尋找員工 (Employee)"
                                     lov-api="@employeeLovApi"
                                     lov-columns="編號,名稱,ID"
                                     lov-fields="employee_no,employee_name,employee_id"
                                     lov-return-value-field="employee_id"
                                     lov-return-display-field="employee_name"
                                     lov-key-hidden="employee_id"
                                     lov-key-code="employee_no"
                                     lov-key-name="employee_name"
                                     selectonly="false"
                                     column-matches='[{"SourceFieldName":"employee_name","TargetFieldName":"agentEmployeeName","RemoteMethod":false}]'
                                     col-span="3">
                        </g-lov-input>

                        <!-- 假別（g-lov-input：只有 name 欄 + 按鈕）-->
                        <g-lov-input label="假別" required="true"
                                     hidden-id="leaveId"
                                     name-id="leaveTypeDisplay"  name-placeholder="請選擇假別"
                                     lov-title="尋找假別 (Leave Type)"
                                     lov-api="@leaveTypeLovApi"
                                     lov-columns="假別編號,假別名稱"
                                     lov-fields="leave_id,leave_name"
                                     lov-key-hidden="leave_id"
                                     lov-display-format="{leave_id} - {leave_name}"
                                     show-button="true"
                                     col-span="2">
                        </g-lov-input>

                        <!-- 請假時間 -->
                        <g-textbox label="請假開始時間 *" name="startTime" type="datetime-local" col-span="3"></g-textbox>
                        <g-textbox label="請假結束時間 *" name="endTime"   type="datetime-local" col-span="3"></g-textbox>

                        <!-- 時數 / 日數 -->
                        <div class="md:col-span-2 flex flex-col gap-1">
                            <label class="text-xs font-semibold text-slate-600 text-xs font-semibold text-slate-600">時數 / 日數</label>
                            <div class="flex">
                                <input type="number" id="leaveHours" placeholder="時數"
                                       class="w-full rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400 block w-1/2 rounded-l-lg rounded-r-none text-sm text-right bg-slate-100">
                                <input type="number" id="leaveDays"  placeholder="日數" readonly
                                       class="w-full rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400 block w-1/2 rounded-r-lg rounded-l-none border-l-0 text-sm bg-slate-100 text-slate-500 text-right">
                            </div>
                        </div>

                        <g-textbox label="刷卡日" name="punchDate" type="date" col-span="2"></g-textbox>

                        <!-- 代理人（g-lov-input）-->
                        <g-lov-input label="代理人員工"
                                     hidden-id="agentEmployeeId"
                                     code-id="agentEmployeeNo"   code-placeholder="員工編號" code-width="w-1/3"
                                     name-id="agentEmployeeName" name-placeholder="姓名"
                                     lov-title="尋找員工 (Employee)"
                                     lov-api="@employeeLovApi"
                                     lov-columns="編號,名稱,ID"
                                     lov-fields="employee_no,employee_name,employee_id"
                                     lov-return-value-field="employee_id"
                                     lov-return-display-field="employee_name"
                                     lov-key-hidden="employee_id"
                                     lov-key-code="employee_no"
                                     lov-key-name="employee_name"
                                     col-span="2">
                        </g-lov-input>

                        <!-- 事由 -->
                        <g-textbox label="事由 *" name="askForLeaveReason" type="textarea"
                                   required="true" rows="2" col-span="6"></g-textbox>

                        <!-- 出差區塊 -->
                        <div class="md:col-span-6 bg-slate-100 rounded-xl p-4 border border-slate-200/70 grid grid-cols-1 md:grid-cols-3 gap-4">
                            <g-textbox label="公出地點" name="destinationPlace" type="text" col-span="1"></g-textbox>
                            <g-textbox label="接洽對象" name="talkingAbout" type="text" col-span="1"></g-textbox>
                            <div class="flex flex-col gap-1">
                                <label class="text-xs font-semibold text-slate-600 text-xs font-semibold text-slate-600">交通工具</label>
                                <div class="flex">
                                    <input type="text" class="w-full rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400 block w-1/3 rounded-l-lg rounded-r-none text-sm bg-slate-100">
                                    <input type="text" readonly class="w-full rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400 block flex-1 rounded-r-lg rounded-l-none border-l-0 text-sm bg-slate-100 text-slate-500">
                                </div>
                            </div>
                            <div class="md:col-span-3 flex flex-wrap items-center gap-6 pt-3 border-t border-slate-200">
                                <div class="flex items-center gap-4 bg-white px-4 py-1.5 rounded border border-slate-200/60">
                                    <label class="inline-flex items-center gap-2 text-xs text-xs font-semibold text-slate-600 cursor-pointer">
                                        <input type="radio" name="return_workplace" value="Y" class="h-4 w-4 border-slate-300 text-blue-600 focus:ring-blue-500">返回工作地點
                                    </label>
                                    <label class="inline-flex items-center gap-2 text-xs text-xs font-semibold text-slate-600 cursor-pointer">
                                        <input type="radio" name="return_workplace" value="N" class="h-4 w-4 border-slate-300 text-blue-600 focus:ring-blue-500" checked>不返回工作地點
                                    </label>
                                </div>
                                <label class="inline-flex items-center gap-2 text-xs text-xs font-semibold text-slate-600 cursor-pointer">
                                    <input type="checkbox" id="overseasYn" value="Y" class="h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500">海外出差
                                </label>
                            </div>
                        </div>

                        <!-- 時數統計（g-textbox readonly）-->
                        <div class="md:col-span-6 grid grid-cols-2 md:grid-cols-4 gap-4 bg-slate-100 p-4 rounded-xl border border-teal-100">
                            <g-textbox label="年度可休時數"           name="yearTotal"   type="text" readonly="true"></g-textbox>
                            <g-textbox label="年度已休時數(不含本次)" name="yearUsed"    type="text" readonly="true"></g-textbox>
                            <g-textbox label="本期可休時數"           name="periodTotal" type="text" readonly="true"></g-textbox>
                            <g-textbox label="本期已休時數(不含本次)" name="periodUsed"  type="text" readonly="true"></g-textbox>
                        </div>

                    </div>

                    <!-- 操作按鈕 -->
                    <div class="mt-6 flex justify-center flex-wrap gap-3 pt-5 border-t border-slate-100">
                        <g-button id="btnSubmit" text="送出申請" icon="check" type="primary" size="lg"></g-button>
                        <g-button text="刪除簽核" icon="trash" type="danger" size="lg"></g-button>
                        <g-button text="不准後重申請" type="ghost" size="lg" disabled="true"></g-button>
                    </div>
                </div>
            </g-tab>

            <!-- Tab 2：附件檔案 -->
            <g-tab title="附件檔案" icon="upload">
                <g-panel title="附件上傳" icon="upload">
                    <p class="text-xs text-red-500 mb-3 font-medium">使用說明：選檔 -> Upload -> 閱讀</p>
                    <div class="overflow-x-auto border border-slate-200 rounded-lg">
                        <table class="w-full text-sm">
                            <thead class="bg-slate-100">
                                <tr>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500 w-8">序</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">附件上傳</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">檔案說明</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500 text-center w-32">操作</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white">
                                @for (int fi = 1; fi <= 3; fi++)
                                {
                                    <tr>
                                        <td class="px-3 py-2 text-xs text-slate-500">@fi</td>
                                        <td class="px-3 py-2 text-sm text-slate-600">
                                            <g-file-uploader id="hrmAttachUploader_@fi"
                                                             label=""
                                                             name="files"
                                                             upload-url="/api/files/upload"
                                                             upload-mode="useButtons"
                                                             folder="hrmgd47"
                                                             accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg"
                                                             allowed-file-extensions=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg"
                                                             multiple="false"
                                                             max-file-size="10485760"
                                                             select-button-text="選擇檔案"
                                                             upload-button-text="Upload"
                                                             cancel-button-text="Clear"
                                                             drop-zone-text="或拖拉檔案到此"
                                                             result-input-id="attachPath_@fi"
                                                             on-uploaded="onHrmAttachmentUploaded">
                                            </g-file-uploader>
                                            <input type="hidden" id="attachPath_@fi" name="attachPath_@fi" value="">
                                        </td>
                                        <td class="px-3 py-2 text-sm text-slate-600">
                                            <input type="text" class="w-full rounded-lg border border-slate-300 px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-400 block w-full text-xs" placeholder="說明...">
                                        </td>
                                        <td class="px-3 py-2 text-sm text-slate-600 text-center space-x-1">
                                            <g-button text="閱讀" icon="eye" type="info" size="sm" onclick="openAttachmentFile(@fi)"></g-button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </g-panel>
            </g-tab>

            <!-- Tab 3：簽核歷程 -->
            <g-tab title="簽核歷程" icon="check">
                <g-panel title="簽核明細記錄" icon="check">
                    <div class="overflow-x-auto border border-slate-200 rounded-lg">
                        <table class="w-full text-sm">
                            <thead class="bg-slate-100">
                                <tr>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">處理者</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">行動</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500 text-center">結果</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">意義</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">簽核意見</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">完成時間</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white">
                                <tr>
                                    <td class="px-3 py-2 text-sm text-slate-600 text-slate-700 font-medium">@ViewBag.UserName</td>
                                    <td class="px-3 py-2 text-sm text-slate-600">申請送出</td>
                                    <td class="px-3 py-2 text-sm text-slate-600 text-center"><span class="bg-slate-100 text-slate-600 inline-block px-2 py-0.5 rounded-full text-xs font-mono">00</span></td>
                                    <td class="px-3 py-2 text-sm text-slate-600">鍵入中</td>
                                    <td class="px-3 py-2 text-sm text-slate-600 text-xs text-slate-500 italic">表單建立</td>
                                    <td class="px-3 py-2 text-sm text-slate-600 text-xs text-slate-500">@DateTime.Now.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                                <tr><td colspan="6" class="py-4"></td></tr>
                            </tbody>
                        </table>
                    </div>
                </g-panel>
            </g-tab>

            <!-- Tab 4：年度特休 -->
            <g-tab title="年度特休" icon="calendar">
                <g-panel title="特休資料查詢" icon="calendar">
                    <div class="flex justify-end mb-3">
                        <g-button text="查詢年度特休" icon="search" type="secondary" size="sm"></g-button>
                    </div>
                    <div class="overflow-hidden rounded-lg border border-slate-200">
                        <table class="w-full text-sm">
                            <thead class="bg-slate-100 text-purple-800">
                                <tr>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">開始日期</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500">結束日期</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500 text-right">可休時數</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500 text-right">實際可休</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold uppercase text-slate-500 text-right">已休時數</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white">
                                <tr class="text-slate-600">
                                    <td class="px-3 py-2 text-sm text-slate-600">2026-01-01</td>
                                    <td class="px-3 py-2 text-sm text-slate-600">2026-12-31</td>
                                    <td class="px-3 py-2 text-sm text-slate-600 text-right font-mono bg-slate-100">120.0</td>
                                    <td class="px-3 py-2 text-sm text-slate-600 text-right font-mono bg-slate-100">120.0</td>
                                    <td class="px-3 py-2 text-sm text-slate-600 text-right font-mono text-pink-600 bg-slate-100">32.5</td>
                                </tr>
                                <tr><td colspan="5" class="py-4"></td></tr>
                            </tbody>
                        </table>
                    </div>
                </g-panel>
            </g-tab>

        </g-tabs>

        <!-- ====================== 狀態列（g-status-bar）====================== -->
        <g-status-bar msg-id="statusBarMsg" record-info="1/1" default-msg="Ready."></g-status-bar>

    </div>
</div>

@section Scripts {
    <g-js profile="popup"></g-js>
    <script>
        function getHrmCurrentEmployeeId() {
            return document.getElementById('employeeId')?.value
                || document.querySelector('[data-lov-name=\"hrmgd47-filter-employee\"] [data-lov-slot=\"hidden\"]')?.value
                || document.getElementById('filterEmployeeId')?.value
                || '';
        }

        function onHrmAttachmentUploaded(payload) {
            const count = payload?.files?.length || 0;
            if (count > 0) {
                gToast(`附件上傳成功 (${count})`, 'success');
            }
        }

        function openAttachmentFile(index) {
            const hidden = document.getElementById(`attachPath_${index}`);
            const filePath = hidden?.value || '';
            if (!filePath) {
                gToast('請先上傳附件', 'warning');
                return;
            }
            window.open(`/Files/Open?path=${encodeURIComponent(filePath)}`, '_blank');
        }

        // ---- 送出申請 ----
        document.addEventListener('DOMContentLoaded', function () {
            const btnSubmit = document.getElementById('btnSubmit');
            const statusBarMsg = document.getElementById('statusBarMsg');

            btnSubmit.addEventListener('click', async function () {
                const employeeId = document.getElementById('employeeId').value;
                const leaveId = document.getElementById('leaveId').value;
                const startTime = document.querySelector('[name=startTime]').value;
                const endTime = document.querySelector('[name=endTime]').value;
                const askForLeaveReason = document.querySelector('[name=askForLeaveReason]').value;

                if (!employeeId || !leaveId || !startTime || !endTime || !askForLeaveReason) {
                    gToast('請填寫所有必填欄位（*號）', 'warning');
                    statusBarMsg.value = '錯誤：必填欄位未填寫完整。';
                    return;
                }
                if (new Date(startTime) >= new Date(endTime)) {
                    gToast('結束時間必須大於開始時間！', 'error');
                    return;
                }

                const payload = {
                    employeeId: parseInt(employeeId, 10),
                    leaveId: parseInt(leaveId, 10),
                    startTime, endTime, askForLeaveReason,
                    leaveHours: document.getElementById('leaveHours').value ? parseFloat(document.getElementById('leaveHours').value) : null,
                    leaveDays: document.getElementById('leaveDays').value ? parseFloat(document.getElementById('leaveDays').value) : null,
                    agentEmployeeId: document.getElementById('agentEmployeeId').value ? parseInt(document.getElementById('agentEmployeeId').value, 10) : null,
                    destinationPlace: document.querySelector('[name=destinationPlace]').value || null,
                    talkingAbout: document.querySelector('[name=talkingAbout]').value || null,
                    returnYn: document.querySelector('input[name="return_workplace"]:checked')?.value || 'N',
                    overseasYn: document.getElementById('overseasYn').checked ? 'Y' : 'N'
                };

                try {
                    statusBarMsg.value = '資料庫寫入中...';
                    btnSubmit.disabled = true;
                    const res = await fetch('/Hrm/submit', {
                        method: 'POST', headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const data = await res.json();
                    if (res.ok && data.status === 'success') {
                        statusBarMsg.value = `Success: ${data.message} (流水號: ${data.id})`;
                        gToast(`申請單建立成功！單號：${data.id}`, 'success');
                    } else {
                        statusBarMsg.value = `Error: ${data.message || '驗證失敗'}`;
                        gToast(`申請失敗：${data.message || '請確認欄位格式'}`, 'error');
                    }
                } catch (e) {
                    statusBarMsg.value = 'Error: 系統例外錯誤。';
                    gToast('系統發生錯誤，無法連線。', 'error');
                } finally {
                    btnSubmit.disabled = false;
                }
            });
        });
    </script>
}
