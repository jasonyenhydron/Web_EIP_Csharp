<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Oracle DBA System</title>
    <!-- Tailwind CSS (CDN for now, adjust based on your original project setup) -->
    <script>
        const originalWarn = console.warn;
        console.warn = function() {
            if (arguments[0] && typeof arguments[0] === 'string' && arguments[0].includes('cdn.tailwindcss.com should not be used in production')) return;
            originalWarn.apply(console, arguments);
        };
    </script>
    <script>
        (function () {
            try {
                var key = "eip.theme";
                var saved = localStorage.getItem(key) || "blue-white";
                document.documentElement.setAttribute("data-theme", saved);
            } catch (e) {
                document.documentElement.setAttribute("data-theme", "blue-white");
            }
        })();
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script defer src="/js/theme.js"></script>
    <g-style profile="layout"></g-style>
    @RenderSection("Styles", required: false)
</head>
<body>
    @* SVG Icon Sprite（全站共用，放 body 最前，不佔版面）*@
    <partial name="~/Views/Shared/_IconSprite.cshtml" />

    @RenderBody()

    @* 全站共用：訊息彈窗 + Toast（放 body 底部）*@
    <g-messager/>
    <g-error-message />

    @RenderSection("Scripts", required: false)
</body>
</html>
