@* Views/Shared/_LovModal.cshtml *@
<div id="genericLovModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden z-[75] items-center justify-center p-4 transition-opacity duration-200">
    <div class="bg-white rounded-lg shadow-2xl w-full max-w-2xl flex flex-col overflow-hidden border border-slate-300">
        <div class="bg-blue-600 text-white px-4 py-2 flex justify-between items-center cursor-move">
            <h3 class="text-sm font-bold flex items-center gap-2" id="genericLovTitle">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                查詢
            </h3>
            <button class="bg-blue-600 p-1 rounded transition-colors" onclick="closeGenericLov()">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <div class="p-4 flex-1 flex flex-col bg-slate-100">
            <div class="flex gap-2 items-center mb-4">
                <label class="text-sm font-bold text-slate-700 whitespace-nowrap">查詢 %</label>
                <input type="text" id="genericLovSearchInput" class="flex-1 border border-slate-300 px-3 py-1.5 rounded-sm shadow-inner text-sm focus:outline-none focus:border-blue-500" placeholder="輸入關鍵字後按 Enter 或查詢">
                <button type="button" class="bg-slate-100 border border-slate-400 px-4 py-1.5 rounded-sm text-sm font-bold text-slate-700 transition-colors shadow-sm" onclick="fetchGenericLovData()">查詢</button>
            </div>

            <div id="genericLovGridWrap" class="border border-slate-300 bg-white flex-1 overflow-auto rounded-sm min-h-[300px] max-h-[400px]">
                <table class="w-full text-left text-sm border-collapse">
                    <thead class="bg-slate-100 text-slate-700 sticky top-0 shadow-sm" id="genericLovThead">
                        <tr></tr>
                    </thead>
                    <tbody id="genericLovTableBody"></tbody>
                </table>
            </div>
        </div>

        <div class="bg-slate-100 border-t border-slate-300 px-4 py-3 flex justify-center gap-4">
            <button type="button" class="bg-white border text-blue-700 border-slate-400 px-6 py-1.5 rounded-sm shadow-sm bg-blue-600 text-sm font-bold transition-colors" onclick="confirmGenericLovSelection()">確定</button>
            <button type="button" class="bg-white border text-slate-700 border-slate-400 px-6 py-1.5 rounded-sm shadow-sm bg-slate-100 text-sm font-bold transition-colors" onclick="closeGenericLov()">取消</button>
        </div>
    </div>
</div>

<script>
    let genericLovState = {
        title: '',
        apiUrl: '',
        columns: [],
        targetInputs: {},
        dataFields: [],
        selectedValue: {},
        currentRow: null,
        formatDisplay: null,
        onConfirmCallback: null,
        onSelectCallback: null,
        columnMatches: [],
        filterItems: [],
        page: 1,
        pageSize: 50,
        bufferView: true,
        sortEnabled: false,
        sortKey: '',
        sortDir: 'asc',
        rows: [],
        hasMore: true,
        loading: false,
        query: ''
    };

    document.addEventListener('DOMContentLoaded', function () {
        const searchInput = document.getElementById('genericLovSearchInput');
        const tableWrap = document.getElementById('genericLovGridWrap');

        if (searchInput) {
            searchInput.addEventListener('keypress', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    fetchGenericLovData();
                }
            });
        }

        if (tableWrap) {
            tableWrap.addEventListener('scroll', function () {
                const nearBottom = tableWrap.scrollTop + tableWrap.clientHeight >= tableWrap.scrollHeight - 40;
                if (genericLovState.bufferView && nearBottom && genericLovState.hasMore && !genericLovState.loading) {
                    fetchGenericLovData(true);
                }
            });
        }
    });

    function openGenericLov(title, apiUrl, columns, dataFields, targetInputs, formatDisplay = null, onConfirmCallback = null, options = null) {
        if (title && typeof title === 'object' && !Array.isArray(title)) {
            const cfg = title;
            return openGenericLov(
                cfg.title || cfg.lovTitle || '查詢',
                cfg.api || cfg.apiUrl || cfg.lovApi || '',
                Array.isArray(cfg.columns) ? cfg.columns : (Array.isArray(cfg.lovColumns) ? cfg.lovColumns : []),
                Array.isArray(cfg.fields) ? cfg.fields : (Array.isArray(cfg.dataFields) ? cfg.dataFields : []),
                cfg.map || cfg.targetInputs || {},
                cfg.formatDisplay || cfg.formatter || null,
                cfg.onConfirm || cfg.onConfirmCallback || null,
                Object.assign({}, cfg.options || {}, {
                    onSelect: cfg.onSelect || null,
                    columnMatches: cfg.columnMatches || [],
                    filterItems: cfg.filterItems || []
                })
            );
        }

        const opts = options || {};
        const pageSize = Number(opts.pageSize) > 0 ? Number(opts.pageSize) : 50;
        const bufferView = opts.bufferView !== false;
        const sortEnabled = opts.sortEnabled === true;

        genericLovState.title = title;
        genericLovState.apiUrl = typeof apiUrl === 'string' ? apiUrl : '';
        genericLovState.columns = Array.isArray(columns) ? columns : [];
        genericLovState.dataFields = Array.isArray(dataFields) ? dataFields : [];
        genericLovState.targetInputs = targetInputs || {};
        genericLovState.formatDisplay = formatDisplay;
        genericLovState.onConfirmCallback = onConfirmCallback;
        genericLovState.onSelectCallback = (opts && typeof opts.onSelect === 'function') ? opts.onSelect : (typeof options?.onSelect === 'function' ? options.onSelect : null);
        genericLovState.columnMatches = Array.isArray(opts.columnMatches) ? opts.columnMatches : [];
        genericLovState.filterItems = Array.isArray(opts.filterItems) ? opts.filterItems : [];
        genericLovState.page = 1;
        genericLovState.pageSize = pageSize;
        genericLovState.bufferView = bufferView;
        genericLovState.sortEnabled = sortEnabled;
        genericLovState.sortKey = '';
        genericLovState.sortDir = 'asc';
        genericLovState.rows = [];
        genericLovState.hasMore = true;
        genericLovState.loading = false;
        genericLovState.query = '';

        document.getElementById('genericLovTitle').innerHTML = `
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            ${title}
        `;

        const thead = document.getElementById('genericLovThead').querySelector('tr');
        function renderGenericLovHeader() {
            thead.innerHTML = '';
            columns.forEach((col, idx) => {
                const key = genericLovState.dataFields[idx];
                const sortable = genericLovState.sortEnabled && !!key;
                const isCurrent = genericLovState.sortKey === key;
                const indicator = !sortable ? '' : (isCurrent ? (genericLovState.sortDir === 'asc' ? '▲' : '▼') : '↕');
                const th = document.createElement('th');
                th.className = `border-b border-r border-slate-300 px-3 py-2 font-bold whitespace-nowrap ${sortable ? 'cursor-pointer select-none bg-blue-600' : ''}`;
                th.innerHTML = `
                    <span class="inline-flex items-center gap-1">
                        <span>${col}</span>
                        ${sortable ? `<span class="text-[11px] ${isCurrent ? 'text-blue-600' : 'text-slate-400'}">${indicator}</span>` : ``}
                    </span>`;
                if (sortable) {
                    th.addEventListener('click', () => {
                        if (genericLovState.sortKey === key) {
                            genericLovState.sortDir = genericLovState.sortDir === 'asc' ? 'desc' : 'asc';
                        } else {
                            genericLovState.sortKey = key;
                            genericLovState.sortDir = 'asc';
                        }
                        renderGenericLovHeader();
                        renderGenericLovTable();
                    });
                }
                thead.appendChild(th);
            });
        }
        renderGenericLovHeader();

        document.getElementById('genericLovTableBody').innerHTML = '';
        document.getElementById('genericLovSearchInput').value = '';

        const modal = document.getElementById('genericLovModal');
        modal.classList.remove('hidden');
        modal.style.display = 'flex';

        setTimeout(() => {
            document.getElementById('genericLovSearchInput').focus();
            fetchGenericLovData();
        }, 100);
    }

    function closeGenericLov() {
        const modal = document.getElementById('genericLovModal');
        modal.classList.add('hidden');
        modal.style.display = 'none';
        genericLovState.selectedValue = {};
        genericLovState.currentRow = null;
    }

    async function fetchGenericLovData(loadMore = false) {
        const tbody = document.getElementById('genericLovTableBody');
        const query = document.getElementById('genericLovSearchInput').value.trim();
        if (genericLovState.loading) return;
        if (!genericLovState.apiUrl) {
            tbody.innerHTML = `<tr><td colspan="${Math.max(genericLovState.columns.length, 1)}" class="text-center py-4 text-red-500">LOV API 未設定</td></tr>`;
            return;
        }

        if (!loadMore || genericLovState.query !== query) {
            genericLovState.page = 1;
            genericLovState.hasMore = true;
            genericLovState.query = query;
            tbody.innerHTML = `<tr><td colspan="${genericLovState.columns.length}" class="text-center py-4 text-slate-500">載入中...</td></tr>`;
            genericLovState.currentRow = null;
        } else if (!genericLovState.bufferView || !genericLovState.hasMore) {
            return;
        } else {
            const loadingRow = document.createElement('tr');
            loadingRow.id = 'genericLovLoadingRow';
            loadingRow.innerHTML = `<td colspan="${genericLovState.columns.length}" class="text-center py-2 text-slate-400 text-xs">載入更多...</td>`;
            tbody.appendChild(loadingRow);
        }

        genericLovState.loading = true;

        try {
            const api = String(genericLovState.apiUrl || '');
            const sep = api.includes('?') ? '&' : '?';
            const extraFilter = await buildFilterQueryString();
            const url = `${api}${sep}query=${encodeURIComponent(query)}&page=${genericLovState.page}&pageSize=${genericLovState.pageSize}${extraFilter}`;
            const response = await fetch(url);
            const result = await response.json();

            if (response.ok && result.status === 'success') {
                if (loadMore && genericLovState.query === query) {
                    genericLovState.rows = [...genericLovState.rows, ...(result.data || [])];
                } else {
                    genericLovState.rows = [...(result.data || [])];
                }
                renderGenericLovTable();
                genericLovState.hasMore = typeof result.hasMore === 'boolean'
                    ? result.hasMore
                    : (Array.isArray(result.data) && result.data.length >= genericLovState.pageSize);
                if (genericLovState.hasMore) genericLovState.page += 1;
            } else {
                if (!loadMore) {
                    tbody.innerHTML = `<tr><td colspan="${genericLovState.columns.length}" class="text-center py-4 text-red-500">Error: ${result.message || '查詢失敗'}</td></tr>`;
                }
            }
        } catch (err) {
            if (!loadMore) {
                tbody.innerHTML = `<tr><td colspan="${genericLovState.columns.length}" class="text-center py-4 text-red-500">Fetch Failed: ${err.message}</td></tr>`;
            }
        } finally {
            const loadingRow = document.getElementById('genericLovLoadingRow');
            if (loadingRow) loadingRow.remove();
            genericLovState.loading = false;
        }
    }

    function renderGenericLovTable() {
        const tbody = document.getElementById('genericLovTableBody');
        tbody.innerHTML = '';

        const source = Array.isArray(genericLovState.rows) ? genericLovState.rows : [];
        const sortKey = genericLovState.sortKey;
        const sortDir = genericLovState.sortDir === 'desc' ? -1 : 1;
        const sorted = !sortKey
            ? source
            : [...source].sort((a, b) => {
                const av = a?.[sortKey] ?? '';
                const bv = b?.[sortKey] ?? '';
                if (av === bv) return 0;
                return av < bv ? -sortDir : sortDir;
            });

        if (!sorted || sorted.length === 0) {
            tbody.innerHTML = `<tr><td colspan="${genericLovState.columns.length}" class="text-center py-4 text-slate-500">查無資料</td></tr>`;
            return;
        }

        sorted.forEach((item, index) => {
            const tr = document.createElement('tr');
            const rowBaseClass = `cursor-pointer transition-colors border-b border-slate-200 ${(index % 2 === 0) ? 'bg-white' : 'bg-slate-50'}`;
            tr.className = rowBaseClass;
            tr.dataset.rowBaseClass = rowBaseClass;
            tr.onclick = function () { selectGenericLovRow(tr, item); };
            tr.ondblclick = function () { selectGenericLovRow(tr, item); confirmGenericLovSelection(); };

            genericLovState.dataFields.forEach((field, fIdx) => {
                const td = document.createElement('td');
                td.className = 'px-3 py-1.5 border-r border-slate-200 truncate max-w-[200px]' + (fIdx === 0 ? ' font-mono text-blue-700' : ' text-slate-700 font-medium');
                td.innerText = item[field] || (item[field] === 0 ? '0' : '');
                tr.appendChild(td);
            });

            tbody.appendChild(tr);

            if (index === 0) {
                selectGenericLovRow(tr, item);
            }
        });
    }

    function selectGenericLovRow(rowElement, rowData) {
        document.querySelectorAll('#genericLovTableBody tr').forEach((tr) => {
            const baseClass = tr.dataset.rowBaseClass || 'cursor-pointer transition-colors border-b border-slate-200 bg-white';
            tr.className = baseClass;
            tr.querySelectorAll('td').forEach(td => td.classList.remove('text-white'));
            tr.querySelector('td:nth-child(1)')?.classList.add('text-blue-700');
            tr.querySelector('td:nth-child(2)')?.classList.add('text-slate-700');
        });

        genericLovState.currentRow = rowElement;
        genericLovState.currentRow.classList.remove('bg-white', 'bg-slate-50');
        genericLovState.currentRow.classList.add('bg-blue-100', 'ring-1', 'ring-inset', 'ring-blue-400');
        genericLovState.currentRow.querySelectorAll('td').forEach(td => {
            td.classList.remove('text-slate-500');
            td.classList.add('text-slate-800');
        });

        genericLovState.selectedValue = rowData;
        if (typeof genericLovState.onSelectCallback === 'function') {
            try { genericLovState.onSelectCallback(rowData); } catch { }
        }
    }

    async function confirmGenericLovSelection() {
        if (genericLovState.selectedValue && Object.keys(genericLovState.selectedValue).length > 0) {
            await applyColumnMatches(genericLovState.selectedValue);
            for (const [dataKey, inputId] of Object.entries(genericLovState.targetInputs)) {
                if (dataKey === 'FORMATTED_DISPLAY' && genericLovState.formatDisplay) {
                    const el = document.getElementById(inputId);
                    if (el) {
                        el.value = genericLovState.formatDisplay(genericLovState.selectedValue);
                        el.dispatchEvent(new Event('input', { bubbles: true }));
                        el.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                } else if (genericLovState.selectedValue[dataKey] !== undefined) {
                    const el = document.getElementById(inputId);
                    if (el) {
                        el.value = genericLovState.selectedValue[dataKey];
                        el.dispatchEvent(new Event('input', { bubbles: true }));
                        el.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                }
            }

            if (genericLovState.onConfirmCallback) {
                genericLovState.onConfirmCallback(genericLovState.selectedValue);
            }

            closeGenericLov();
        } else {
            alert('請先選擇一筆資料');
        }
    }

    async function resolveDynamicValue(methodName, fallbackValue, payload) {
        if (typeof methodName === 'string' && methodName.trim()) {
            const fn = window[methodName.trim()];
            if (typeof fn === 'function') {
                const v = fn(payload);
                return (v && typeof v.then === 'function') ? await v : v;
            }
        }
        return fallbackValue;
    }

    async function buildFilterQueryString() {
        const items = Array.isArray(genericLovState.filterItems) ? genericLovState.filterItems : [];
        if (!items.length) return '';

        const parts = [];
        for (const item of items) {
            const fieldName = (item?.FieldName ?? item?.FiledName ?? '').toString().trim();
            if (!fieldName) continue;
            const whereField = (item?.WhereField ?? '').toString().trim();
            const whereMethod = (item?.WhereMethod ?? '').toString().trim();
            let value = (item?.WhereValue ?? '');

            if (whereField) {
                const el = document.getElementById(whereField);
                if (el && typeof el.value !== 'undefined') value = el.value;
            }
            value = await resolveDynamicValue(whereMethod, value, { item, state: genericLovState });
            if (value === undefined || value === null || `${value}` === '') continue;
            parts.push(`${encodeURIComponent(fieldName)}=${encodeURIComponent(value)}`);
        }

        return parts.length ? `&${parts.join('&')}` : '';
    }

    async function applyColumnMatches(selected) {
        const matches = Array.isArray(genericLovState.columnMatches) ? genericLovState.columnMatches : [];
        if (!matches.length || !selected) return;

        for (const m of matches) {
            const sourceField = (m?.SourceFieldName ?? '').toString().trim();
            const sourceMethod = (m?.SourceMethod ?? '').toString().trim();
            const targetField = (m?.TargetFieldName ?? '').toString().trim();
            if (!targetField) continue;

            let value = sourceField ? selected?.[sourceField] : undefined;
            value = await resolveDynamicValue(sourceMethod, value, { row: selected, match: m, state: genericLovState });

            const el = document.getElementById(targetField);
            if (!el) continue;
            el.value = value ?? '';
            el.dispatchEvent(new Event('input', { bubbles: true }));
            el.dispatchEvent(new Event('change', { bubbles: true }));
        }
    }

    (function initGLovApi() {
        const registry = {};

        function merge(base, extra) {
            return Object.assign({}, base || {}, extra || {});
        }

        function openByName(name, overrides = {}) {
            const key = String(name || '').trim();
            const base = registry[key];
            if (!base) {
                alert(`LOV 設定不存在: ${key}`);
                return;
            }
            const cfg = merge(base, overrides);
            if (base.options || overrides.options) {
                cfg.options = merge(base.options, overrides.options);
            }
            if (base.map || overrides.map) {
                cfg.map = merge(base.map, overrides.map);
            }
            if (base.columnMatches || overrides.columnMatches) {
                cfg.columnMatches = Array.isArray(overrides.columnMatches) ? overrides.columnMatches : (Array.isArray(base.columnMatches) ? base.columnMatches : []);
            }
            if (base.filterItems || overrides.filterItems) {
                cfg.filterItems = Array.isArray(overrides.filterItems) ? overrides.filterItems : (Array.isArray(base.filterItems) ? base.filterItems : []);
            }
            return openGenericLov(cfg);
        }

        window.gLov = window.gLov || {};
        window.gLov.define = (name, config) => {
            const key = String(name || '').trim();
            if (!key) return;
            registry[key] = merge(config, {});
        };
        window.gLov.openByName = openByName;
        window.gLov.open = (config) => openGenericLov(config);
        window.gLov.openLegacy = (...args) => openGenericLov(...args);
        window.gLov._registry = registry;
    })();

    window.openGenericLov = function (...args) {
        return openGenericLov(...args);
    };
</script>
