<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <!-- Tailwind CSS -->
    <script>
        const originalWarn = console.warn;
        console.warn = function() {
            // Guard null/undefined arguments[0] to avoid TypeError.
            if (arguments.length > 0 && arguments[0] != null && typeof arguments[0] === 'string' &&
                arguments[0].includes('cdn.tailwindcss.com should not be used in production')) return;
            originalWarn.apply(console, arguments);
        };
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <g-style profile="popup"></g-style>
    <style>
        .g-popup-scroll-root { overflow: hidden !important; }
        body.g-modal-open .g-popup-scroll-root { overflow: hidden !important; }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body class="bg-slate-50 overflow-hidden h-screen flex flex-col">
    @* SVG Icon Sprite *@
    <partial name="~/Views/Shared/_IconSprite.cshtml" />

    <div class="g-popup-scroll-root flex-1 min-h-0 relative overflow-hidden">
        @RenderBody()
    </div>

    <div class="shrink-0 border-t border-slate-200 bg-white/95 backdrop-blur px-4 py-2 flex justify-end">
        <button type="button"
                onclick="gPopupTryClose()"
                class="inline-flex items-center justify-center px-4 py-2 rounded-lg border border-slate-300 bg-slate-100 text-slate-700 hover:bg-slate-200 transition-colors shadow-sm"
                title="關閉">
            關閉
        </button>
    </div>

    @* Global message / toast components *@
    <g-messager/>
    <g-error-message />

    @* SweetAlert2 *@
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @* LOV modal component *@
    <partial name="~/Views/Shared/_LovModal.cshtml" />


    <script>
        function gPopupHasUnsavedChanges() {
            if (window.__hasUnsavedChanges === true) return true;

            const stateSelectors = [
                '[data-dataform-state="edit"]',
                '[data-dataform-state="insert"]',
                '[data-form-mode="edit"]',
                '[data-form-mode="insert"]',
                '[data-form-mode="create"]',
                '[data-record-mode="edit"]',
                '[data-record-mode="insert"]',
                '[data-record-mode="create"]'
            ];
            if (document.querySelector(stateSelectors.join(','))) return true;

            const grids = document.querySelectorAll('[id]');
            for (const el of grids) {
                const g = el.gDataGrid;
                if (g && g.editingId !== null && g.editingId !== undefined && g.editingId !== '') {
                    return true;
                }
            }

            const appCandidates = [window._idmApp, window._hrmApp, window._app];
            for (const app of appCandidates) {
                const mode = app?.recordMode;
                if (mode === 'edit' || mode === 'create' || mode === 'insert') {
                    return true;
                }
            }

            return false;
        }

        function gPopupDoClose() {
            if (window.opener) {
                window.close();
                return;
            }
            history.back();
        }

        function gPopupTryClose() {
            if (!gPopupHasUnsavedChanges()) {
                gPopupDoClose();
                return;
            }

            const msg = '目前資料尚未存檔，確定要離開嗎？';
            if (window.Swal && typeof window.Swal.fire === 'function') {
                window.Swal.fire({
                    title: '尚未存檔',
                    text: msg,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: '離開',
                    cancelButtonText: '取消'
                }).then((r) => {
                    if (r.isConfirmed) gPopupDoClose();
                });
                return;
            }

            if (window.confirm(msg)) {
                gPopupDoClose();
            }
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>




