<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <!-- Tailwind CSS -->
    <script>
        const originalWarn = console.warn;
        console.warn = function() {
            // Guard null/undefined arguments[0] to avoid TypeError.
            if (arguments.length > 0 && arguments[0] != null && typeof arguments[0] === 'string' &&
                arguments[0].includes('cdn.tailwindcss.com should not be used in production')) return;
            originalWarn.apply(console, arguments);
        };
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <g-style profile="popup"></g-style>
    <style>
        html, body {
            height: 100%;
        }
        body {
            margin: 0 !important;
            margin-bottom: 0 !important;
        }
        .g-popup-scroll-root { overflow: auto !important; }
        body.g-modal-open .g-popup-scroll-root { overflow: hidden !important; }
        .g-popup-titlebar {
            background: #6b7280;
            color: #fff;
            border-bottom: 1px solid rgba(255, 255, 255, 0.15);
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
@{
    var showPopupTitleBar = (ViewData["ShowPopupTitleBar"] as bool?) ?? true;
    var showPopupBottomPanelClose = (ViewData["ShowPopupBottomPanelClose"] as bool?) ?? true;
}
<body class="bg-slate-100 min-h-screen flex flex-col">
    @* SVG Icon Sprite *@
    <partial name="~/Views/Shared/_IconSprite.cshtml" />

    @if (showPopupTitleBar)
    {
        <div class="g-popup-titlebar shrink-0 h-16 px-6 flex items-center">
            <div class="text-3xl font-semibold tracking-wide truncate">@ViewData["Title"]</div>
        </div>
    }

    <div class="g-popup-scroll-root flex-1 min-h-0 relative overflow-y-auto overflow-x-auto overscroll-contain">
        @RenderBody()
    </div>

    @if (showPopupBottomPanelClose)
    {
        <div class="shrink-0 border-t border-slate-300 bg-slate-200/60 px-4 py-2 flex justify-end">
            <button type="button"
                    onclick="gPopupTryClose()"
                    class="inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-semibold text-white bg-rose-600 hover:bg-rose-700 transition-colors shadow"
                    title="關閉">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6l12 12M18 6L6 18"/>
                </svg>
                關閉
            </button>
        </div>
    }

    @* Global message / toast components *@
    <g-messager/>
    <g-error-message />

    @* LOV modal component *@
    <partial name="~/Views/Shared/_LovModal.cshtml" />


    <script>
        function gPopupHasUnsavedChanges() {
            if (window.__hasUnsavedChanges === true) return true;

            const stateSelectors = [
                '[data-dataform-state="edit"]',
                '[data-dataform-state="insert"]',
                '[data-form-mode="edit"]',
                '[data-form-mode="insert"]',
                '[data-form-mode="create"]',
                '[data-record-mode="edit"]',
                '[data-record-mode="insert"]',
                '[data-record-mode="create"]'
            ];
            if (document.querySelector(stateSelectors.join(','))) return true;

            const grids = document.querySelectorAll('[id]');
            for (const el of grids) {
                const g = el.gDataGrid;
                if (g && g.editingId !== null && g.editingId !== undefined && g.editingId !== '') {
                    return true;
                }
            }

            const appCandidates = [window._idmApp, window._hrmApp, window._app];
            for (const app of appCandidates) {
                const mode = app?.recordMode;
                if (mode === 'edit' || mode === 'create' || mode === 'insert') {
                    return true;
                }
            }

            return false;
        }

        function gPopupDoClose() {
            if (window.opener) {
                window.close();
                return;
            }
            history.back();
        }

        function gPopupTryClose() {
            if (!gPopupHasUnsavedChanges()) {
                gPopupDoClose();
                return;
            }

            const msg = '目前資料尚未存檔，確定要離開嗎？';
            if (window.gMsg && typeof window.gMsg.confirm === 'function') {
                window.gMsg.confirm(
                    '尚未存檔',
                    msg,
                    () => gPopupDoClose(),
                    null,
                    'warning'
                );
                return;
            }

            if (window.confirm(msg)) {
                gPopupDoClose();
            }
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
