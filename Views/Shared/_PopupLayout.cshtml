@{
    var title = (ViewData["Title"]?.ToString() ?? "").Trim();
    var showPopupTitleBar = (ViewData["ShowPopupTitleBar"] as bool?) ?? false;
    var showPopupBottomPanel = (ViewData["ShowPopupBottomPanel"] as bool?) ?? true;
    var bottomButtonsRaw = (ViewData["PopupBottomButtons"]?.ToString() ?? "close").ToLowerInvariant();
    var bottomButtons = bottomButtonsRaw
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Select(x => x.Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);
    if (bottomButtons.Count == 0) bottomButtons.Add("close");
    var bottomButtonsHtml = ViewData["PopupBottomButtonsHtml"]?.ToString() ?? "";

    var baseWindowMovable = (ViewData["BaseWindowMovable"] as bool?) ?? true;
    var baseWindowResizable = (ViewData["BaseWindowResizable"] as bool?) ?? true;
    var baseWindowMaximizable = (ViewData["BaseWindowMaximizable"] as bool?) ?? true;
    var baseWindowStartMaximized = (ViewData["BaseWindowStartMaximized"] as bool?) ?? true;
    var baseWindowClosable = (ViewData["BaseWindowClosable"] as bool?) ?? true;
    var baseWindowMinWidth = (ViewData["BaseWindowMinWidth"]?.ToString() ?? "640").Trim();
    var baseWindowMinHeight = (ViewData["BaseWindowMinHeight"]?.ToString() ?? "420").Trim();
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script>
        const originalWarn = console.warn;
        console.warn = function () {
            if (arguments.length > 0 && arguments[0] != null && typeof arguments[0] === "string" &&
                arguments[0].includes("cdn.tailwindcss.com should not be used in production")) return;
            originalWarn.apply(console, arguments);
        };
    </script>
    <script>
        (function () {
            try {
                var key = "eip.theme";
                var saved = localStorage.getItem(key) || "blue-white";
                document.documentElement.setAttribute("data-theme", saved);
            } catch (e) {
                document.documentElement.setAttribute("data-theme", "blue-white");
            }
        })();
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/htmx.org@1.9.12"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script defer src="/js/theme.js"></script>
    <g-style profile="popup"></g-style>
    <style>
        html, body {
            width: 100%;
            height: 100%;
        }

        body {
            margin: 0 !important;
            overflow: hidden;
            background: var(--dx-overlay, rgba(15, 23, 42, 0.22));
        }

        .g-base-window-layer {
            position: fixed;
            inset: 0;
            overflow: hidden;
        }

        .g-popup-window {
            position: absolute;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%);
            width: 95vw;
            height: 95vh;
            max-width: 95vw;
            max-height: 95vh;
            min-width: 320px;
            min-height: 260px;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            border-radius: 14px;
            border: 1px solid var(--dx-border, #94a3b8);
            background: var(--dx-surface, #f8fafc);
            box-shadow: 0 14px 48px rgba(30, 64, 175, 0.25);
            transition: box-shadow .15s ease;
        }

        .g-popup-window.is-maximized {
            left: 0 !important;
            top: 0 !important;
            transform: none !important;
            width: 100% !important;
            height: 100% !important;
            max-width: 100% !important;
            max-height: 100% !important;
            border-radius: 0;
            border-width: 0;
        }

        .g-popup-window.is-dragging,
        .g-popup-window.is-resizing {
            user-select: none;
            box-shadow: 0 20px 56px rgba(15, 23, 42, 0.45);
        }

        .g-popup-titlebar {
            background: var(--dx-brand, #4f5ee8);
            color: #fff;
            border-bottom: 1px solid rgba(255, 255, 255, 0.18);
            cursor: move;
        }

        .g-popup-titlebar.no-move {
            cursor: default;
        }

        .g-popup-title-btn {
            border: 1px solid transparent;
            background: transparent;
            color: rgba(255, 255, 255, 0.88);
        }

        .g-popup-title-btn:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.16);
        }

        .g-popup-content {
            overflow: auto;
            min-height: 0;
            scrollbar-gutter: stable both-edges;
            padding: 0 !important;
        }

        .g-popup-content > .absolute.inset-0 {
            margin: 0 !important;
            padding: 0 !important;
        }

        .g-popup-resize-handle {
            position: absolute;
            right: 0;
            bottom: 0;
            width: 14px;
            height: 14px;
            cursor: nwse-resize;
            z-index: 30;
            background: linear-gradient(135deg, transparent 0 40%, #94a3b8 40% 48%, transparent 48% 58%, #94a3b8 58% 66%, transparent 66% 100%);
            opacity: .7;
        }

        .g-popup-window.is-maximized .g-popup-resize-handle {
            display: none;
        }

        body.g-modal-open .g-popup-content {
            overflow: hidden !important;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>

<body>
    <partial name="~/Views/Shared/_IconSprite.cshtml" />

    <div class="g-base-window-layer">
        <div id="gBaseWindow"
             class="g-popup-window @(baseWindowStartMaximized ? "is-maximized" : "")"
             data-min-width="@baseWindowMinWidth"
             data-min-height="@baseWindowMinHeight"
             data-movable="@baseWindowMovable.ToString().ToLowerInvariant()"
             data-resizable="@baseWindowResizable.ToString().ToLowerInvariant()"
             data-maximizable="@baseWindowMaximizable.ToString().ToLowerInvariant()">
            @if (showPopupTitleBar)
            {
                <div id="gBaseTitlebar" class="g-popup-titlebar shrink-0 h-16 px-5 flex items-center justify-between @(baseWindowMovable ? "" : "no-move")">
                    <div class="text-3xl font-semibold tracking-wide truncate">@title</div>
                    <div class="flex items-center gap-2">
                        @if (baseWindowMaximizable)
                        {
                            <button type="button" class="g-popup-title-btn h-9 w-9 rounded-md inline-flex items-center justify-center transition-colors"
                                    title="放大" onclick="gPopupSetWindowMode('max')">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 3H5a2 2 0 00-2 2v3m16-5h-3m3 0v3M3 16v3a2 2 0 002 2h3m11-5v3a2 2 0 01-2 2h-3"/>
                                </svg>
                            </button>
                            <button type="button" class="g-popup-title-btn h-9 w-9 rounded-md inline-flex items-center justify-center transition-colors"
                                    title="還原" onclick="gPopupSetWindowMode('normal')">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
                                </svg>
                            </button>
                        }
                        @if (baseWindowClosable)
                        {
                            <button type="button" class="g-popup-title-btn h-9 w-9 rounded-md inline-flex items-center justify-center transition-colors"
                                    title="關閉" onclick="gPopupTryClose()">
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6l12 12M18 6L6 18"/>
                                </svg>
                            </button>
                        }
                    </div>
                </div>
            }

            <div class="g-popup-content flex-1 relative">
                @RenderBody()
            </div>

            @if (showPopupBottomPanel)
            {
                <div class="shrink-0 border-t border-slate-300 bg-slate-200/70 px-4 py-2 flex justify-end items-center gap-2">
                    @Html.Raw(bottomButtonsHtml)
                    @if (bottomButtons.Contains("close") && baseWindowClosable)
                    {
                        <button type="button"
                                onclick="gPopupTryClose()"
                                class="inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-semibold text-white bg-rose-600 hover:bg-rose-700 transition-colors shadow"
                                title="關閉">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6l12 12M18 6L6 18"/>
                            </svg>
                            關閉
                        </button>
                    }
                </div>
            }

            @if (baseWindowResizable)
            {
                <div id="gBaseResizeHandle" class="g-popup-resize-handle" title="拖曳調整大小"></div>
            }
        </div>
    </div>

    <g-messager />
    <g-error-message />
    <partial name="~/Views/Shared/_LovModal.cshtml" />

    <script>
        (function () {
            const box = document.getElementById("gBaseWindow");
            const titlebar = document.getElementById("gBaseTitlebar");
            const resizeHandle = document.getElementById("gBaseResizeHandle");
            if (!box) return;

            const canMove = box.dataset.movable === "true";
            const canResize = box.dataset.resizable === "true";
            const canMax = box.dataset.maximizable === "true";
            const minWidth = parseInt(box.dataset.minWidth || "640", 10);
            const minHeight = parseInt(box.dataset.minHeight || "420", 10);

            const state = {
                dragging: false,
                resizing: false,
                startX: 0,
                startY: 0,
                startLeft: 0,
                startTop: 0,
                startWidth: 0,
                startHeight: 0,
                prevRect: null
            };

            const captureRect = () => {
                const r = box.getBoundingClientRect();
                return { left: r.left, top: r.top, width: r.width, height: r.height };
            };

            const applyRect = (rect) => {
                if (!rect) return;
                const vw = window.innerWidth;
                const vh = window.innerHeight;
                const width = Math.min(Math.max(minWidth, rect.width), vw);
                const height = Math.min(Math.max(minHeight, rect.height), vh);
                const left = Math.min(Math.max(0, rect.left), Math.max(0, vw - width));
                const top = Math.min(Math.max(0, rect.top), Math.max(0, vh - height));
                box.style.left = `${left}px`;
                box.style.top = `${top}px`;
                box.style.width = `${width}px`;
                box.style.height = `${height}px`;
                box.style.transform = "none";
            };

            function setWindowMode(mode) {
                if (!canMax && mode === "max") return;

                if (mode === "max") {
                    if (!box.classList.contains("is-maximized")) state.prevRect = captureRect();
                    box.classList.add("is-maximized");
                    return;
                }

                if (mode === "toggle") {
                    setWindowMode(box.classList.contains("is-maximized") ? "normal" : "max");
                    return;
                }

                box.classList.remove("is-maximized");
                if (state.prevRect) {
                    applyRect(state.prevRect);
                } else {
                    box.style.left = "50%";
                    box.style.top = "50%";
                    box.style.width = "95vw";
                    box.style.height = "95vh";
                    box.style.transform = "translate(-50%, -50%)";
                }
            }

            window.gPopupSetWindowMode = setWindowMode;

            if (canMove && titlebar) {
                titlebar.addEventListener("mousedown", (e) => {
                    if (box.classList.contains("is-maximized")) return;
                    if (e.button !== 0) return;
                    if (e.target.closest("button")) return;

                    const rect = box.getBoundingClientRect();
                    state.dragging = true;
                    state.startX = e.clientX;
                    state.startY = e.clientY;
                    state.startLeft = rect.left;
                    state.startTop = rect.top;
                    box.classList.add("is-dragging");
                    box.style.transform = "none";
                    e.preventDefault();
                });

                window.addEventListener("mousemove", (e) => {
                    if (!state.dragging) return;
                    const dx = e.clientX - state.startX;
                    const dy = e.clientY - state.startY;
                    const width = box.offsetWidth;
                    const height = box.offsetHeight;
                    const maxLeft = Math.max(0, window.innerWidth - width);
                    const maxTop = Math.max(0, window.innerHeight - height);
                    const nextLeft = Math.min(Math.max(0, state.startLeft + dx), maxLeft);
                    const nextTop = Math.min(Math.max(0, state.startTop + dy), maxTop);
                    box.style.left = `${nextLeft}px`;
                    box.style.top = `${nextTop}px`;
                });

                window.addEventListener("mouseup", () => {
                    if (!state.dragging) return;
                    state.dragging = false;
                    box.classList.remove("is-dragging");
                    state.prevRect = captureRect();
                });
            }

            if (canResize && resizeHandle) {
                resizeHandle.addEventListener("mousedown", (e) => {
                    if (box.classList.contains("is-maximized")) return;
                    if (e.button !== 0) return;

                    const rect = box.getBoundingClientRect();
                    state.resizing = true;
                    state.startX = e.clientX;
                    state.startY = e.clientY;
                    state.startWidth = rect.width;
                    state.startHeight = rect.height;
                    box.classList.add("is-resizing");
                    box.style.transform = "none";
                    e.preventDefault();
                });

                window.addEventListener("mousemove", (e) => {
                    if (!state.resizing) return;
                    const dx = e.clientX - state.startX;
                    const dy = e.clientY - state.startY;
                    const maxWidth = window.innerWidth - box.offsetLeft;
                    const maxHeight = window.innerHeight - box.offsetTop;
                    const nextWidth = Math.min(Math.max(minWidth, state.startWidth + dx), maxWidth);
                    const nextHeight = Math.min(Math.max(minHeight, state.startHeight + dy), maxHeight);
                    box.style.width = `${nextWidth}px`;
                    box.style.height = `${nextHeight}px`;
                });

                window.addEventListener("mouseup", () => {
                    if (!state.resizing) return;
                    state.resizing = false;
                    box.classList.remove("is-resizing");
                    state.prevRect = captureRect();
                });
            }

            if (canMax && titlebar) {
                titlebar.addEventListener("dblclick", (e) => {
                    if (e.target.closest("button")) return;
                    setWindowMode("toggle");
                });
            }

            window.addEventListener("resize", () => {
                if (box.classList.contains("is-maximized")) return;
                applyRect(captureRect());
                state.prevRect = captureRect();
            });

            window.addEventListener("keydown", (e) => {
                if (e.key === "Escape") window.gPopupTryClose?.();
            });
        })();

        function gPopupHasUnsavedChanges() {
            if (window.__hasUnsavedChanges === true) return true;

            const stateSelectors = [
                "[data-dataform-state='edit']",
                "[data-dataform-state='insert']",
                "[data-form-mode='edit']",
                "[data-form-mode='insert']",
                "[data-form-mode='create']",
                "[data-record-mode='edit']",
                "[data-record-mode='insert']",
                "[data-record-mode='create']"
            ];
            if (document.querySelector(stateSelectors.join(","))) return true;

            const grids = document.querySelectorAll("[id]");
            for (const el of grids) {
                const g = el.gDataGrid;
                if (g && g.editingId !== null && g.editingId !== undefined && g.editingId !== "") {
                    return true;
                }
            }

            const appCandidates = [window._idmApp, window._hrmApp, window._cmmgd16App, window._app];
            for (const app of appCandidates) {
                const mode = app?.recordMode;
                if (mode === "edit" || mode === "create" || mode === "insert") return true;
            }

            return false;
        }

        function gPopupDoClose() {
            if (window.parent && window.parent !== window && typeof window.parent.closeExecutionModal === "function") {
                window.parent.closeExecutionModal();
                return;
            }
            if (window.opener) {
                window.close();
                return;
            }
            history.back();
        }

        function gPopupTryClose() {
            if (!gPopupHasUnsavedChanges()) {
                gPopupDoClose();
                return;
            }

            const msg = "尚有未儲存的變更，確定要關閉嗎？";
            if (window.gMsg && typeof window.gMsg.confirm === "function") {
                window.gMsg.confirm("關閉確認", msg, () => gPopupDoClose(), null, "warning");
                return;
            }
            if (window.confirm(msg)) gPopupDoClose();
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
