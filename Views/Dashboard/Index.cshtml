@{
    ViewData["Title"] = "金可國際-永勝光學";
}

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <style>
        html { scroll-behavior: smooth; }
        body { font-family: "Noto Sans TC", sans-serif; }
        .fade-in-section {
            opacity: 0;
            transform: translateY(20px);
            visibility: hidden;
            transition: opacity .8s ease-out, transform .8s ease-out;
        }
        .fade-in-section.is-visible {
            opacity: 1;
            transform: none;
            visibility: visible;
        }
        .hero-bg {
            background-image: linear-gradient(rgba(15, 76, 129, .82), rgba(15, 76, 129, .92)), url('https://images.unsplash.com/photo-1576091160550-2173ff9e5eb3?q=80&w=2069&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }
    </style>
}

<nav class="fixed w-full z-50 bg-white/95 backdrop-blur-sm shadow-sm transition-all duration-300" id="navbar">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
            <div class="flex items-center">
                <svg class="h-10 w-10 text-teal-500 animate-spin" style="animation-duration:8s" viewBox="0 0 100 100" fill="none">
                    <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="4" stroke-dasharray="10 20"></circle>
                    <circle cx="50" cy="50" r="30" stroke="#0F4C81" stroke-width="6" opacity="0.8"></circle>
                    <circle cx="50" cy="50" r="15" fill="#20B2AA"></circle>
                </svg>
                <div class="ml-3">
                    <h1 class="text-xl font-bold text-[#0F4C81] tracking-wider">永勝光學</h1>
                    <p class="text-xs text-gray-500 tracking-widest">金可國際集團</p>
                </div>
            </div>
            <div class="hidden md:flex items-center gap-8">
                <a href="#about" class="text-gray-600 hover:text-teal-500 font-medium">關於我們</a>
                <a href="#tech" class="text-gray-600 hover:text-teal-500 font-medium">核心技術</a>
                <a href="#quality" class="text-gray-600 hover:text-teal-500 font-medium">品質保證</a>
                <a href="#contact" class="text-gray-600 hover:text-teal-500 font-medium">聯絡資訊</a>
            </div>
            <div class="flex items-center">
                <a href="/Account/Login"
                   class="bg-[#0F4C81] hover:bg-blue-800 text-white px-6 py-2 rounded-full font-medium transition-shadow shadow-md hover:shadow-lg">
                    企業內部入口網站
                </a>
            </div>
        </div>
    </div>
</nav>

<section class="hero-bg relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center lg:text-left flex flex-col lg:flex-row items-center">
        <div class="lg:w-1/2 text-white">
            <div class="inline-block bg-teal-400/20 border border-teal-300/40 rounded-full px-4 py-1 mb-6 backdrop-blur-sm">
                <span class="text-teal-200 font-bold text-sm tracking-widest">亞洲光學領導品牌</span>
            </div>
            <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-tight mb-6">
                清晰視界<br>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-300 to-blue-300">守護您的健康雙眸</span>
            </h2>
            <p class="text-lg sm:text-xl text-gray-200 mb-10 max-w-2xl mx-auto lg:mx-0 font-light">
                永勝光學隸屬金可國際集團，以世界級尖端高分子生醫技術，為全球提供安全、舒適、高透氧的隱形眼鏡產品。
