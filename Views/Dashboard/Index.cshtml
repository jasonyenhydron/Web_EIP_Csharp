                <button class="bg-white/10 hover:bg-white/20 border border-white/30 text-white px-8 py-4 rounded-full font-bold text-lg backdrop-blur-sm">了解企業願景</button>
            </div>
        </div>
        <div class="lg:w-1/2 mt-16 lg:mt-0 flex justify-center lg:justify-end">
            <div class="relative w-72 h-72 sm:w-96 sm:h-96">
                <svg class="absolute inset-0 w-full h-full text-teal-300/40 animate-spin" style="animation-duration:8s" viewBox="0 0 200 200">
                    <path fill="currentColor" d="M44.7,-76.4C58.3,-69.2,70,-56.3,78.5,-41.5C87,-26.7,92.3,-10.1,91.3,6.1C90.3,22.3,83.1,38.1,72.3,50.6C61.5,63.1,47.1,72.4,31.4,78.8C15.7,85.2,-1.3,88.7,-17.6,84.9C-33.9,81.1,-49.5,70,-60.8,56.3C-72.1,42.6,-79.1,26.4,-82.1,9.8C-85.1,-6.8,-84.1,-23.8,-76.3,-37.5C-68.5,-51.2,-53.9,-61.6,-39.4,-68.3C-24.9,-75,-12.4,-78,2.7,-81.2C17.8,-84.4,31.1,-83.6,44.7,-76.4Z" transform="translate(100 100) scale(1.1)"></path>
                </svg>
                <img src="https://images.unsplash.com/photo-1589828131802-1815db47ff82?q=80&w=1000&auto=format&fit=crop" alt="專業實驗室" class="absolute inset-4 rounded-full object-cover shadow-2xl border-4 border-white/20">
            </div>
        </div>
    </div>
    <div class="absolute bottom-0 w-full overflow-hidden leading-none">
