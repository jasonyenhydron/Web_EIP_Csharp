@{
    ViewData["Title"] = "Dashboard";
    ViewBag.HeaderTitle = "Dashboard";
}

<div class="flex h-screen bg-slate-50 overflow-hidden">
    <partial name="Components/_Sidebar" />

    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
        <partial name="Components/_Header" />

        <main class="flex-1 overflow-auto p-6">
            <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm mb-6">
                <h1 class="text-2xl font-bold text-slate-800">Welcome, @(ViewBag.UserName ?? ViewBag.Username ?? "User")</h1>
                <p class="text-slate-500 mt-2">Today: @DateTime.Now.ToString("yyyy-MM-dd")</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
                    <div class="text-sm text-slate-500">Pending Tasks</div>
                    <div class="text-3xl font-bold text-slate-800 mt-1">12</div>
                </div>
                <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
                    <div class="text-sm text-slate-500">Open Approvals</div>
                    <div class="text-3xl font-bold text-slate-800 mt-1">5</div>
                </div>
                <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
                    <div class="text-sm text-slate-500">System Status</div>
                    <div class="text-lg font-semibold text-emerald-600 mt-2">Online</div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <section class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
                    <h2 class="text-lg font-semibold text-slate-700 mb-3">Announcements</h2>
                    <ul class="space-y-3 text-sm text-slate-600">
                        <li class="border-b border-slate-100 pb-2">ERP monthly maintenance: 2026-03-10 22:00</li>
                        <li class="border-b border-slate-100 pb-2">New IDM permission request process is now available</li>
                        <li>Reminder: complete HRM profile updates before month end</li>
                    </ul>
                </section>

                <section class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm">
                    <h2 class="text-lg font-semibold text-slate-700 mb-3">Quick Links</h2>
                    <div class="grid grid-cols-2 gap-3 text-sm">
                        <a href="/mis/programs" class="px-3 py-2 rounded-lg bg-slate-100 hover:bg-slate-200 text-slate-700">MIS Programs</a>
                        <a href="/Idm/IDMGD01" class="px-3 py-2 rounded-lg bg-slate-100 hover:bg-slate-200 text-slate-700">IDM Program</a>
                        <a href="/Hrm/HRMGD47" class="px-3 py-2 rounded-lg bg-slate-100 hover:bg-slate-200 text-slate-700">HRM Leave</a>
                        <a href="/Account/Logout" class="px-3 py-2 rounded-lg bg-slate-100 hover:bg-slate-200 text-slate-700">Logout</a>
                    </div>
                </section>
            </div>
        </main>
    </div>
</div>

@section Scripts {
    <g-js profile="main"></g-js>
}
